// Constants for the simulation
let nx = 41
let ny = 41
let nt = 500
let nit = 50
let _c = 1.0
let dx : Double = 2.0 / (nx - 1).to_double()
let dy : Double = 2.0 / (ny - 1).to_double()
let rho = 1.0
let nu = 0.1
let dt = 0.001
// ── Local run configuration ───────────────────────────────────────────────────
// These constants control `moon run cmd/main` (local workflow) only.
// They have NO effect on the exported WASM API used by the browser viewer.

/// Master on/off switch for timing output.
/// false = suppress all [Timing] lines (solvers still run normally).
let timing_enabled : Bool = true

/// Time the Chorin solver init and run phases individually.
let time_chorin_phase : Bool = true

/// Time the SIMPLE solver init and run phases individually.
let time_simple_phase : Bool = true

/// Include the Chorin (projection-method, explicit time-marching) solver.
let run_chorin : Bool = true

/// Chorin time steps to execute locally.  Maximum = nt = 500.
/// Set to e.g. 100 for a faster preview run.
let local_nt : Int = nt

/// Include the SIMPLE (steady-state, pressure-correction) solver.
let run_simple : Bool = true

/// Number of SIMPLE iterations to execute locally.
let local_simple_n : Int = 100

// ── Timing helper ─────────────────────────────────────────────────────────────
// Backed by @bench.monotonic_clock_start / monotonic_clock_end, which are
// implemented natively for both --target native and --target wasm via the
// Wasmtime host import "__moonbit_time_unstable"."instant_now".

/// Execute f(), measure wall-clock elapsed time, return milliseconds.
/// Prints a labelled line when enabled=true. Returns 0.0 when enabled=false.
fn timed(enabled : Bool, label : String, f : () -> Unit) -> Double {
  if not(enabled) {
    f()
    0.0
  } else {
    let ts = @bench.monotonic_clock_start()
    f()
    let ms = @bench.monotonic_clock_end(ts) / 1000.0
    println("[Timing] \{label}: \{ms} ms")
    ms
  }
}

// ── Global simulation state (written by init_simulation / run_all_steps) ──
// These are allocated once; JS calls init_simulation() before run_all_steps().
let g_u : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

let g_v : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

let g_p : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

// ── Global step counter (single-element array, writable at global scope) ──
let g_steps : Array[Int] = [0]

// ── Primitive accessors exported to WASM ──

/// Return grid width (nx).
pub fn get_nx() -> Int { nx }

/// Return grid height (ny).
pub fn get_ny() -> Int { ny }

/// Return total time-step count (nt).
pub fn get_nt() -> Int { nt }

/// Return Reynolds number Re = u_lid * L / nu  (u_lid=1, L=2).
pub fn get_re() -> Double { 1.0 * 2.0 / nu }

/// Return number of pressure Poisson inner iterations per time step (nit).
pub fn get_nit() -> Int { nit }

/// Return grid spacing in x.
pub fn get_dx() -> Double { dx }

/// Return grid spacing in y.
pub fn get_dy() -> Double { dy }

/// Return time step size dt.
pub fn get_dt() -> Double { dt }

/// Return fluid density rho.
pub fn get_rho() -> Double { rho }

/// Return kinematic viscosity nu.
pub fn get_nu() -> Double { nu }

/// Return how many solver steps have been executed since the last init_simulation().
pub fn get_step_count() -> Int { g_steps[0] }

/// Reset the global u, v, p arrays to zero so a fresh simulation can start.
/// JS must call this before run_all_steps().
pub fn init_simulation() -> Unit {
  g_steps[0] = 0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u[i][j] = 0.0
      g_v[i][j] = 0.0
      g_p[i][j] = 0.0
    }
  }
}

/// Read u-velocity at grid index (i=row, j=col).  Returns 0 for out-of-range.
pub fn get_u_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_u[i][j] } else { 0.0 }
}

/// Read v-velocity at grid index (i=row, j=col).  Returns 0 for out-of-range.
pub fn get_v_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_v[i][j] } else { 0.0 }
}

/// Read pressure at grid index (i=row, j=col).  Returns 0 for out-of-range.
pub fn get_p_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_p[i][j] } else { 0.0 }
}

/// Return velocity magnitude sqrt(u²+v²) at grid index (i,j).
pub fn get_velocity_magnitude_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx {
    let u = g_u[i][j]
    let v = g_v[i][j]
    (u * u + v * v).sqrt()
  } else {
    0.0
  }
}

/// Return maximum absolute u-velocity over the whole grid.
pub fn get_max_u() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let v = g_u[i][j].abs()
      if v > m { m = v }
    }
  }
  m
}

/// Return maximum absolute v-velocity over the whole grid.
pub fn get_max_v() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let v = g_v[i][j].abs()
      if v > m { m = v }
    }
  }
  m
}

/// Return maximum pressure value over the whole grid.
pub fn get_max_p() -> Double {
  let mut m = g_p[0][0]
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      if g_p[i][j] > m { m = g_p[i][j] }
    }
  }
  m
}

/// Return minimum pressure value over the whole grid.
pub fn get_min_p() -> Double {
  let mut m = g_p[0][0]
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      if g_p[i][j] < m { m = g_p[i][j] }
    }
  }
  m
}

/// Return u at the grid centre (ny/2, nx/2) – convenient for convergence monitoring.
pub fn get_u_center() -> Double { g_u[ny / 2][nx / 2] }

/// Return v at the grid centre.
pub fn get_v_center() -> Double { g_v[ny / 2][nx / 2] }

/// Return pressure at the grid centre.
pub fn get_p_center() -> Double { g_p[ny / 2][nx / 2] }

/// Return mean absolute divergence ∑|∂u/∂x + ∂v/∂y| / (interior cells) as a
/// rough indicator of how well mass conservation is satisfied after the last step.
pub fn get_divergence_norm() -> Double {
  let mut sum = 0.0
  let count = (ny - 2) * (nx - 2)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let div = (g_u[i][j + 1] - g_u[i][j - 1]) / (2.0 * dx) +
                (g_v[i + 1][j] - g_v[i - 1][j]) / (2.0 * dy)
      sum = sum + div.abs()
    }
  }
  if count > 0 { sum / count.to_double() } else { 0.0 }
}

/// Return the maximum velocity magnitude sqrt(u²+v²) over the whole grid.
pub fn get_max_velocity_magnitude() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let u = g_u[i][j]
      let v = g_v[i][j]
      let mag = (u * u + v * v).sqrt()
      if mag > m { m = mag }
    }
  }
  m
}

/// Run exactly n time steps starting from the current global state.
/// JS can call this in chunks to implement progressive visualization.
/// init_simulation() must be called once before the first chunk.
pub fn run_n_steps(n : Int) -> Unit {
  let (u_out, v_out, p_out) = cavity_flow_array(
    n, g_u, g_v, dt, dx, dy, g_p, rho, nu,
  )
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u[i][j] = u_out[i][j]
      g_v[i][j] = v_out[i][j]
      g_p[i][j] = p_out[i][j]
    }
  }
  g_steps[0] = g_steps[0] + n
}

/// Run the full cavity-flow solver (nt steps) and store results in g_u/g_v/g_p.
/// JS workflow:  init_simulation() → run_all_steps() → get_u_at/get_v_at/get_p_at
pub fn run_all_steps() -> Unit {
  let (u_out, v_out, p_out) = cavity_flow_array(
    nt, g_u, g_v, dt, dx, dy, g_p, rho, nu,
  )
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u[i][j] = u_out[i][j]
      g_v[i][j] = v_out[i][j]
      g_p[i][j] = p_out[i][j]
    }
  }
  g_steps[0] = nt
}

// Helper function to create 2D array filled with zeros
fn create_zeros_2d(rows : Int, cols : Int) -> Array[Array[Double]] {
  let result = Array::make(rows, Array::make(cols, 0.0))
  for i = 0; i < rows; i = i + 1 {
    result[i] = Array::make(cols, 0.0)
  }
  result
}
// Helper function to copy 2D array
fn copy_2d_array(src : Array[Array[Double]], dst : Array[Array[Double]]) -> Unit {
  for i = 0; i < src.length(); i = i + 1 {
    for j = 0; j < src[i].length(); j = j + 1 {
      dst[i][j] = src[i][j]
    }
  }
}
// Generate mesh coordinates (equivalent to numpy.linspace and meshgrid)
fn generate_mesh_grid() -> (Array[Array[Double]], Array[Array[Double]]) {
  let x_coords = Array::make(nx, 0.0)
  let y_coords = Array::make(ny, 0.0)
  
  // Generate x coordinates (0 to 2)
  for i = 0; i < nx; i = i + 1 {
    x_coords[i] = 2.0 * i.to_double() / (nx - 1).to_double()
  }
  
  // Generate y coordinates (0 to 2)
  for j = 0; j < ny; j = j + 1 {
    y_coords[j] = 2.0 * j.to_double() / (ny - 1).to_double()
  }
  
  // Create meshgrid - 修正：为每行创建新的数组
  let x = Array::make(ny, Array::make(nx, 0.0))
  let y = Array::make(ny, Array::make(nx, 0.0))
  
  for i = 0; i < ny; i = i + 1 {
    x[i] = Array::make(nx, 0.0)  // 为每行创建新数组
    y[i] = Array::make(nx, 0.0)  // 为每行创建新数组
    for j = 0; j < nx; j = j + 1 {
      x[i][j] = x_coords[j]
      y[i][j] = y_coords[i]
    }
  }
  
  (x, y)
}
// [Layer 2 input] Build the right-hand-side source term b for the pressure
// Poisson linear system  Ax = b,  where x = p (Chorin) or x = p' (SIMPLE).
// b encodes the velocity divergence: b = ρ/dt · ∇·u  (plus higher-order terms).
fn build_up_b_array(b : Array[Array[Double]], rho : Double, dt : Double,
                   u : Array[Array[Double]], v : Array[Array[Double]],
                   dx : Double, dy : Double) -> Array[Array[Double]] {
  
  // Equivalent to b[1:-1, 1:-1] = ... in Python
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      // Calculate velocity divergence terms
      let du_dx = (u[i][j + 1] - u[i][j - 1]) / (2.0 * dx)
      let dv_dy = (v[i + 1][j] - v[i - 1][j]) / (2.0 * dy)
      
      // Calculate squared terms
      let du_dx_squared = du_dx * du_dx
      let dv_dy_squared = dv_dy * dv_dy
      
      // Mixed derivative terms
      let du_dy = (u[i + 1][j] - u[i - 1][j]) / (2.0 * dy)
      let dv_dx = (v[i][j + 1] - v[i][j - 1]) / (2.0 * dx)
      let mixed_term = 2.0 * du_dy * dv_dx
      
      // Assemble the source term
      b[i][j] = rho * (
        (1.0 / dt) * (du_dx + dv_dy) - 
        du_dx_squared - 
        mixed_term - 
        dv_dy_squared
      )
    }
  }
  
  b
}
// [Layer 2: Linear equation solver] Gauss-Seidel iterative solver for the
// pressure Poisson equation  ∇²p = b  (or ∇²p' = b for SIMPLE).
// Performs `nit` sweeps over interior nodes; boundary conditions are re-applied
// each sweep.  Both Chorin and SIMPLE share this single implementation.
fn pressure_poisson_array(p : Array[Array[Double]], dx : Double, dy : Double,
                         b : Array[Array[Double]]) -> Array[Array[Double]] {
  let pn = create_zeros_2d(ny, nx)
  let dx2 = dx * dx
  let dy2 = dy * dy
  let coeff = dx2 * dy2 / (2.0 * (dx2 + dy2))
  let inv_denom = 1.0 / (2.0 * (dx2 + dy2))
  
  for q = 0; q < nit; q = q + 1 {
    copy_2d_array(p, pn)
    
    // Update interior points: p[1:-1, 1:-1] = ...
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let laplacian = (pn[i][j + 1] + pn[i][j - 1]) * dy2 + 
                       (pn[i + 1][j] + pn[i - 1][j]) * dx2
        
        p[i][j] = laplacian * inv_denom - coeff * b[i][j]
      }
    }
    
    // Apply boundary conditions
    // p[:, -1] = p[:, -2]  (dp/dx = 0 at x = 2)
    for i = 0; i < ny; i = i + 1 {
      p[i][nx - 1] = p[i][nx - 2]
    }
    
    // p[0, :] = p[1, :]  (dp/dy = 0 at y = 0)
    for j = 0; j < nx; j = j + 1 {
      p[0][j] = p[1][j]
    }
    
    // p[:, 0] = p[:, 1]  (dp/dx = 0 at x = 0)
    for i = 0; i < ny; i = i + 1 {
      p[i][0] = p[i][1]
    }
    
    // p[-1, :] = 0  (p = 0 at y = 2)
    for j = 0; j < nx; j = j + 1 {
      p[ny - 1][j] = 0.0
    }
  }
  
  p
}
// [Layer 1: Pressure-velocity coupling algorithm] Chorin projection method
// (Chorin 1968, operator splitting / fractional-step method):
//   Each time step:
//     1. Explicit scheme velocity prediction (no linear system – direct substitution)
//     2. Build Poisson source term  b = ρ/dt · ∇·ũ
//     3. Gauss-Seidel solve  ∇²p = b  (Layer 2, `nit` inner iterations)
//     4. Project  u ← ũ − (dt/ρ) ∇p  (explicit update, enforces ∇·u = 0)
//   Repeats for `nt` time steps (transient simulation).
///|
fn cavity_flow_array(
  nt : Int,
  u : Array[Array[Double]],
  v : Array[Array[Double]],
  dt : Double,
  dx : Double,
  dy : Double,
  p : Array[Array[Double]],
  rho : Double,
  nu : Double,
) -> (Array[Array[Double]], Array[Array[Double]], Array[Array[Double]]) {
  let un = create_zeros_2d(ny, nx)
  let vn = create_zeros_2d(ny, nx)
  let b = create_zeros_2d(ny, nx)

  for n = 0; n < nt; n = n + 1 {
    copy_2d_array(u, un)
    copy_2d_array(v, vn)

    // Build divergence source term b  [Layer 2 input]
    build_up_b_array(b, rho, dt, u, v, dx, dy) |> ignore

    // Gauss-Seidel solve  ∇²p = b  [Layer 2 linear equation solver]
    pressure_poisson_array(p, dx, dy, b) |> ignore

    // Explicit scheme velocity update (projection step, no linear system)
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let conv_u_x = un[i][j] * dt / dx * (un[i][j] - un[i][j - 1])
        let conv_u_y = vn[i][j] * dt / dy * (un[i][j] - un[i - 1][j])
        let pressure_grad = dt / (2.0 * rho * dx) * (p[i][j + 1] - p[i][j - 1])
        let visc_u_x = nu *
          dt /
          (dx * dx) *
          (un[i][j + 1] - 2.0 * un[i][j] + un[i][j - 1])
        let visc_u_y = nu *
          dt /
          (dy * dy) *
          (un[i + 1][j] - 2.0 * un[i][j] + un[i - 1][j])

        u[i][j] = un[i][j] -
          conv_u_x -
          conv_u_y -
          pressure_grad +
          visc_u_x +
          visc_u_y
      }
    }

    // Update v velocity component
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let conv_v_x = un[i][j] * dt / dx * (vn[i][j] - vn[i][j - 1])
        let conv_v_y = vn[i][j] * dt / dy * (vn[i][j] - vn[i - 1][j])
        let pressure_grad = dt / (2.0 * rho * dy) * (p[i + 1][j] - p[i - 1][j])
        let visc_v_x = nu *
          dt /
          (dx * dx) *
          (vn[i][j + 1] - 2.0 * vn[i][j] + vn[i][j - 1])
        let visc_v_y = nu *
          dt /
          (dy * dy) *
          (vn[i + 1][j] - 2.0 * vn[i][j] + vn[i - 1][j])

        v[i][j] = vn[i][j] -
          conv_v_x -
          conv_v_y -
          pressure_grad +
          visc_v_x +
          visc_v_y
      }
    }

    // Apply velocity boundary conditions
    // u[0, :] = 0, u[:, 0] = 0, u[:, -1] = 0
    for j = 0; j < nx; j = j + 1 {
      u[0][j] = 0.0
    }
    for i = 0; i < ny; i = i + 1 {
      u[i][0] = 0.0
      u[i][nx - 1] = 0.0
    }
    // u[-1, :] = 1 (cavity lid velocity)
    for j = 0; j < nx; j = j + 1 {
      u[ny - 1][j] = 1.0
    }

    // v[0, :] = 0, v[-1, :] = 0, v[:, 0] = 0, v[:, -1] = 0
    for j = 0; j < nx; j = j + 1 {
      v[0][j] = 0.0
      v[ny - 1][j] = 0.0
    }
    for i = 0; i < ny; i = i + 1 {
      v[i][0] = 0.0
      v[i][nx - 1] = 0.0
    }

    // Progress output every 10 steps
    if (n + 1) % 10 == 0 {
      println("Time step \{n + 1}/\{nt} completed")
    }
  }

  (u, v, p)
}

// ── JSON output for local run results ────────────────────────────────────────
//
// Outputs a single JSON document that contains results for BOTH solvers (Chorin
// and SIMPLE).  The "statistics"/"grid" keys hold Chorin data for backward
// compatibility with existing local_viewer.html files; the "simple_statistics"/
// "simple_grid" keys hold SIMPLE data.  "config.solver" records which solvers
// actually ran ("chorin" | "simple" | "both").

/// Compute field statistics over a u/v/p grid.
/// Returns (max_|u|, max_|v|, max_p, min_p, max_|V|, div_norm, center_u, center_v, center_p).
fn field_stats(
  u : Array[Array[Double]],
  v : Array[Array[Double]],
  p : Array[Array[Double]],
) -> (Double, Double, Double, Double, Double, Double, Double, Double, Double) {
  let mut mu = 0.0; let mut mv = 0.0
  let mut mp = p[0][0]; let mut np_ = p[0][0]; let mut mm = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let au = u[i][j].abs(); let av = v[i][j].abs()
      if au > mu { mu = au }
      if av > mv { mv = av }
      if p[i][j] > mp { mp = p[i][j] }
      if p[i][j] < np_ { np_ = p[i][j] }
      let mag = (u[i][j] * u[i][j] + v[i][j] * v[i][j]).sqrt()
      if mag > mm { mm = mag }
    }
  }
  let mut ds = 0.0
  let dc = (ny - 2) * (nx - 2)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let d = (u[i][j + 1] - u[i][j - 1]) / (2.0 * dx) +
              (v[i + 1][j] - v[i - 1][j]) / (2.0 * dy)
      ds = ds + d.abs()
    }
  }
  let dn = if dc > 0 { ds / dc.to_double() } else { 0.0 }
  let mi = ny / 2; let mj = nx / 2
  (mu, mv, mp, np_, mm, dn, u[mi][mj], v[mi][mj], p[mi][mj])
}

/// Emit the JSON "statistics" object for a solver's field.
fn emit_stats(
  mu : Double, mv : Double, mp : Double, np_ : Double,
  mm : Double, dn : Double, cu : Double, cv : Double, cp : Double,
  elapsed_ms : Double,
) -> Unit {
  println("    \"max_u\": \{mu}, \"max_v\": \{mv},")
  println("    \"max_p\": \{mp}, \"min_p\": \{np_},")
  println("    \"max_velocity_magnitude\": \{mm},")
  println("    \"divergence_norm\": \{dn},")
  println("    \"center_u\": \{cu}, \"center_v\": \{cv},")
  println("    \"center_p\": \{cp},")
  println("    \"elapsed_seconds\": \{elapsed_ms / 1000.0}")
}

/// Emit a named JSON grid array for a u/v/p field.
/// json_key  – the JSON property name (e.g. "grid" or "simple_grid")
/// trailing_comma – append a "," after the closing "]" when true
fn emit_grid(
  json_key : String,
  u : Array[Array[Double]],
  v : Array[Array[Double]],
  p : Array[Array[Double]],
  trailing_comma : Bool,
) -> Unit {
  println("  \"\{json_key}\": [")
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let x_pos = 2.0 * j.to_double() / (nx - 1).to_double()
      let y_pos = 2.0 * i.to_double() / (ny - 1).to_double()
      let mag = (u[i][j] * u[i][j] + v[i][j] * v[i][j]).sqrt()
      let comma = if i == ny - 1 && j == nx - 1 { "" } else { "," }
      println("    {\"i\":\{i},\"j\":\{j},\"x\":\{x_pos},\"y\":\{y_pos},\"u\":\{u[i][j]},\"v\":\{v[i][j]},\"p\":\{p[i][j]},\"magnitude\":\{mag}}\{comma}")
    }
  }
  if trailing_comma {
    println("  ],")
  } else {
    println("  ]")
  }
}

/// Output full dual-solver JSON to stdout (delimited by JSON_DATA markers).
///
/// Parameters:
///   u_c/v_c/p_c  – Chorin final fields (g_u / g_v / g_p)
///   nt_c         – Chorin steps executed
///   u_s/v_s/p_s  – SIMPLE final fields (g_u_s / g_v_s / g_p_s)
///   n_s          – SIMPLE iterations executed
///   res_s        – SIMPLE last continuity residual
///   ci/cr/si/sr  – per-phase timing in ms (0.0 when timing disabled)
///   total_ms     – total program elapsed ms
fn output_json(
  u_c : Array[Array[Double]], v_c : Array[Array[Double]], p_c : Array[Array[Double]],
  nt_c : Int,
  u_s : Array[Array[Double]], v_s : Array[Array[Double]], p_s : Array[Array[Double]],
  n_s : Int, res_s : Double,
  u_pcg : Array[Array[Double]], v_pcg : Array[Array[Double]], p_pcg : Array[Array[Double]],
  nt_pcg : Int,
  nt_mac : Int,
  ci_ms : Double, cr_ms : Double,
  si_ms : Double, sr_ms : Double,
  pi_ms : Double, pr_ms : Double,
  mi_ms : Double, mr_ms : Double,
  total_ms : Double,
) -> Unit {
  let solver_str = if run_chorin && run_simple && run_pcg && run_mac { "all" }
                   else if run_chorin && run_simple && run_pcg { "chorin_simple_pcg" }
                   else if run_chorin && run_simple { "both" }
                   else if run_chorin { "chorin" }
                   else { "simple" }

  let (cmu, cmv, cmp, cnp, cmm, cdn, ccu, ccv, ccp) = field_stats(u_c, v_c, p_c)
  let (smu, smv, smp, snp, smm, sdn, scu, scv, scp) = field_stats(u_s, v_s, p_s)
  let (pmu, pmv, pmp, pnp, pmm, pdn, pcu, pcv, pcp) = field_stats(u_pcg, v_pcg, p_pcg)
  let (mmu, mmv, mmp, mnp, mmm, mdn, mcu, mcv, mcp) = field_stats_mac()

  println("===JSON_DATA_START===")
  println("{")
  println("  \"config\": {")
  println("    \"nx\": \{nx}, \"ny\": \{ny}, \"nt\": \{nt_c},")
  println("    \"nit\": \{nit}, \"dt\": \{dt}, \"dx\": \{dx}, \"dy\": \{dy},")
  println("    \"rho\": \{rho}, \"nu\": \{nu}, \"re\": \{1.0 * 2.0 / nu},")
  println("    \"solver\": \"\{solver_str}\",")
  println("    \"simple_iters\": \{n_s},")
  println("    \"pcg_steps\": \{nt_pcg},")
  println("    \"pcg_tol\": \{pcg_tol}, \"pcg_max_iter\": \{pcg_max_iter},")
  println("    \"mac_steps\": \{nt_mac}, \"mac_nc\": \{mac_nc}")
  println("  },")
  println("  \"timing\": {")
  println("    \"enabled\": \{timing_enabled},")
  println("    \"chorin_init_ms\": \{ci_ms}, \"chorin_run_ms\": \{cr_ms},")
  println("    \"simple_init_ms\": \{si_ms}, \"simple_run_ms\": \{sr_ms},")
  println("    \"pcg_init_ms\": \{pi_ms}, \"pcg_run_ms\": \{pr_ms},")
  println("    \"mac_init_ms\": \{mi_ms}, \"mac_run_ms\": \{mr_ms},")
  println("    \"total_ms\": \{total_ms}")
  println("  },")
  // ── Chorin section (backward-compatible keys "statistics" + "grid") ──
  println("  \"statistics\": {")
  emit_stats(cmu, cmv, cmp, cnp, cmm, cdn, ccu, ccv, ccp, ci_ms + cr_ms)
  println("  },")
  emit_grid("grid", u_c, v_c, p_c, true)
  // ── SIMPLE section ──
  println("  \"simple_statistics\": {")
  println("    \"residual\": \{res_s},")
  emit_stats(smu, smv, smp, snp, smm, sdn, scu, scv, scp, si_ms + sr_ms)
  println("  },")
  emit_grid("simple_grid", u_s, v_s, p_s, true)
  // ── Chorin-PCG section ──
  println("  \"pcg_statistics\": {")
  emit_stats(pmu, pmv, pmp, pnp, pmm, pdn, pcu, pcv, pcp, pi_ms + pr_ms)
  println("  },")
  emit_grid("pcg_grid", u_pcg, v_pcg, p_pcg, true)
  // ── Staggered MAC section ──
  println("  \"mac_statistics\": {")
  emit_stats(mmu, mmv, mmp, mnp, mmm, mdn, mcu, mcv, mcp, mi_ms + mr_ms)
  println("  },")
  emit_grid_mac("mac_grid", false)
  println("}")
  println("===JSON_DATA_END===")
}

// ── [Layer 1: Pressure-velocity coupling algorithm] SIMPLE ──────────────────
// Semi-Implicit Method for Pressure-Linked Equations
// (Patankar & Spalding 1972, steady-state predictor-corrector iteration):
//
// Each SIMPLE sweep:
//   1. Momentum predictor (explicit scheme): u*, v* from current p*  – no linear system
//   2. Build pressure-correction source  b = −∇·u*  (Layer 2 input)
//   3. Gauss-Seidel solve  ∇²p' = b  (Layer 2, `nit` inner iterations)
//   4. Update:  p = p* + α_p · p'
//               u = u* − (dt/ρ) · ∂p'/∂x,  v = v* − (dt/ρ) · ∂p'/∂y
//   5. Apply boundary conditions; compute convergence residual ‖div u‖
//   Repeat until residual < tolerance.
//
// Under-relaxation factors:
let simple_alpha_p : Double = 0.3   // pressure under-relaxation (stabilises convergence)
let simple_alpha_u : Double = 0.7   // velocity under-relaxation

// Global SIMPLE state arrays (same 41×41 grid as the original solver)
let g_u_s : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

let g_v_s : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

let g_p_s : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

// Iteration counter and convergence residual for SIMPLE
let g_simple_iters    : Array[Int]    = [0]
let g_simple_residual : Array[Double] = [0.0]

/// Reset the SIMPLE global state to zero so a fresh solve can start.
pub fn init_simple() -> Unit {
  g_simple_iters[0]    = 0
  g_simple_residual[0] = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u_s[i][j] = 0.0
      g_v_s[i][j] = 0.0
      g_p_s[i][j] = 0.0
    }
  }
}

/// Return the number of SIMPLE iterations completed since init_simple().
pub fn get_simple_step_count() -> Int { g_simple_iters[0] }

/// Return the latest continuity residual ‖div u‖ from SIMPLE.
pub fn get_simple_residual() -> Double { g_simple_residual[0] }

/// Read SIMPLE u-velocity at grid index (i, j).  Returns 0 for out-of-range.
pub fn get_u_simple_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_u_s[i][j] } else { 0.0 }
}

/// Read SIMPLE v-velocity at grid index (i, j).  Returns 0 for out-of-range.
pub fn get_v_simple_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_v_s[i][j] } else { 0.0 }
}

/// Read SIMPLE pressure at grid index (i, j).  Returns 0 for out-of-range.
pub fn get_p_simple_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_p_s[i][j] } else { 0.0 }
}

/// Return maximum absolute u from the SIMPLE field.
pub fn get_max_u_simple() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let v = g_u_s[i][j].abs()
      if v > m { m = v }
    }
  }
  m
}

/// Return mean |∂u/∂x + ∂v/∂y| for the SIMPLE velocity field.
pub fn get_simple_divergence_norm() -> Double {
  let mut sum = 0.0
  let count = (ny - 2) * (nx - 2)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let div = (g_u_s[i][j + 1] - g_u_s[i][j - 1]) / (2.0 * dx) +
                (g_v_s[i + 1][j] - g_v_s[i - 1][j]) / (2.0 * dy)
      sum = sum + div.abs()
    }
  }
  if count > 0 { sum / count.to_double() } else { 0.0 }
}

// One SIMPLE sweep (Layer 1 inner step):
//   (a) Momentum predictor (explicit scheme) → u*, v*  [no linear system]
//   (b) Build divergence source b  [Layer 2 input]
//   (c) Gauss-Seidel solve  ∇²p' = b  [Layer 2 linear equation solver]
//   (d) Field update with under-relaxation
//   (e) Boundary conditions
fn simple_one_iter(
  u  : Array[Array[Double]],
  v  : Array[Array[Double]],
  p  : Array[Array[Double]],
) -> Unit {
  // Working arrays (allocated per-call; 41×41 is small so overhead is acceptable)
  let u_star = create_zeros_2d(ny, nx)
  let v_star = create_zeros_2d(ny, nx)
  let b      = create_zeros_2d(ny, nx)
  let p_corr = create_zeros_2d(ny, nx)

  // ── (a) Momentum predictor (explicit Euler with under-relaxation) ──
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let conv_u_x = u[i][j] * dt / dx * (u[i][j] - u[i][j - 1])
      let conv_u_y = v[i][j] * dt / dy * (u[i][j] - u[i - 1][j])
      let pg_u     = dt / (2.0 * rho * dx) * (p[i][j + 1] - p[i][j - 1])
      let visc_u_x = nu * dt / (dx * dx) * (u[i][j + 1] - 2.0 * u[i][j] + u[i][j - 1])
      let visc_u_y = nu * dt / (dy * dy) * (u[i + 1][j] - 2.0 * u[i][j] + u[i - 1][j])
      let visc_u   = visc_u_x + visc_u_y
      let u_new    = u[i][j] - conv_u_x - conv_u_y - pg_u + visc_u
      u_star[i][j] = simple_alpha_u * u_new + (1.0 - simple_alpha_u) * u[i][j]

      let conv_v_x = u[i][j] * dt / dx * (v[i][j] - v[i][j - 1])
      let conv_v_y = v[i][j] * dt / dy * (v[i][j] - v[i - 1][j])
      let pg_v     = dt / (2.0 * rho * dy) * (p[i + 1][j] - p[i - 1][j])
      let visc_v_x = nu * dt / (dx * dx) * (v[i][j + 1] - 2.0 * v[i][j] + v[i][j - 1])
      let visc_v_y = nu * dt / (dy * dy) * (v[i + 1][j] - 2.0 * v[i][j] + v[i - 1][j])
      let visc_v   = visc_v_x + visc_v_y
      let v_new    = v[i][j] - conv_v_x - conv_v_y - pg_v + visc_v
      v_star[i][j] = simple_alpha_u * v_new + (1.0 - simple_alpha_u) * v[i][j]
    }
  }

  // BCs for u*, v* – walls first, lid last
  for j = 0; j < nx; j = j + 1 {
    u_star[0][j] = 0.0
    v_star[0][j] = 0.0
    v_star[ny - 1][j] = 0.0
  }
  for i = 0; i < ny; i = i + 1 {
    u_star[i][0]      = 0.0
    u_star[i][nx - 1] = 0.0
    v_star[i][0]      = 0.0
    v_star[i][nx - 1] = 0.0
  }
  for j = 0; j < nx; j = j + 1 {
    u_star[ny - 1][j] = 1.0
  }

  // ── (b) Build pressure-correction source b = −(∂u*/∂x + ∂v*/∂y) ──
  build_up_b_array(b, rho, dt, u_star, v_star, dx, dy) |> ignore

  // ── (c) Gauss-Seidel solve  ∇²p' = b  (Layer 2 linear equation solver) ──
  pressure_poisson_array(p_corr, dx, dy, b) |> ignore

  // ── (d) Update fields with under-relaxation ──
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      p[i][j] = p[i][j] + simple_alpha_p * p_corr[i][j]
      u[i][j] = u_star[i][j] - dt / (2.0 * rho * dx) * (p_corr[i][j + 1] - p_corr[i][j - 1])
      v[i][j] = v_star[i][j] - dt / (2.0 * rho * dy) * (p_corr[i + 1][j] - p_corr[i - 1][j])
    }
  }

  // Pressure BCs (same as existing solver)
  for i = 0; i < ny; i = i + 1 {
    p[i][0]      = p[i][1]
    p[i][nx - 1] = p[i][nx - 2]
  }
  for j = 0; j < nx; j = j + 1 {
    p[0][j]      = p[1][j]
    p[ny - 1][j] = 0.0
  }

  // Velocity BCs – apply walls first, lid last so corners take lid value
  for j = 0; j < nx; j = j + 1 {
    u[0][j] = 0.0
    v[0][j] = 0.0
    v[ny - 1][j] = 0.0
  }
  for i = 0; i < ny; i = i + 1 {
    u[i][0]      = 0.0
    u[i][nx - 1] = 0.0
    v[i][0]      = 0.0
    v[i][nx - 1] = 0.0
  }
  // Lid BC applied last so it overrides corner values
  for j = 0; j < nx; j = j + 1 {
    u[ny - 1][j] = 1.0
  }
}

/// Advance the SIMPLE solver by n iterations.
/// Call init_simple() once before the first invocation.
pub fn run_simple_n_iter(n : Int) -> Unit {
  for _k = 0; _k < n; _k = _k + 1 {
    simple_one_iter(g_u_s, g_v_s, g_p_s)
  }
  g_simple_iters[0] = g_simple_iters[0] + n
  // Compute and cache the continuity residual after this batch
  g_simple_residual[0] = get_simple_divergence_norm()
}

// ── [Layer 2: Linear equation solver] Preconditioned Conjugate Gradient ──────
//
// Replaces Gauss-Seidel for the pressure Poisson equation  ∇²p = b.
// The 5-point Laplacian A is symmetric negative definite (with at least one
// Dirichlet BC → p = 0 at lid). PCG works on −A, which is SPD.
//
// Preconditioner: Jacobi (M = diag(A)).  For a uniform grid the diagonal is
// constant at interior nodes: a_diag = 2/dx² + 2/dy².
//
// Stopping criterion: ‖r_k‖ / ‖b‖ < pcg_tol   or   k ≥ pcg_max_iter.
// Reference: Hestenes & Stiefel (1952), J. Res. NIST 49(6).

/// Maximum PCG iterations per pressure solve.
let pcg_max_iter : Int = 200

/// Relative residual tolerance for PCG convergence.
let pcg_tol : Double = 1.0e-5

/// Whether to run the Chorin-PCG solver in the local `moon run` workflow.
let run_pcg : Bool = true

/// Number of Chorin-PCG time steps to execute in the local workflow.
let local_pcg_nt : Int = nt

// Apply standard cavity-flow pressure BCs (shared by GS and PCG solvers).
//   dp/dx = 0  at left/right walls  (Neumann)
//   dp/dy = 0  at bottom            (Neumann)
//   p = 0      at top lid           (Dirichlet)
fn apply_pressure_bcs(p : Array[Array[Double]]) -> Unit {
  for i = 0; i < ny; i = i + 1 {
    p[i][0]      = p[i][1]        // left  wall: ghost = interior
    p[i][nx - 1] = p[i][nx - 2]  // right wall: ghost = interior
  }
  for j = 0; j < nx; j = j + 1 {
    p[0][j]      = p[1][j]   // bottom: ghost = interior
    p[ny - 1][j] = 0.0       // top lid: Dirichlet p = 0
  }
}

// Matrix-free 5-point Laplacian:  lv[i][j] = (∇² v)[i][j]  at interior nodes.
// Boundary values of v must be set before calling (BCs applied by the caller).
fn laplacian_apply(v : Array[Array[Double]], lv : Array[Array[Double]],
                   inv_dx2 : Double, inv_dy2 : Double, a_diag : Double) -> Unit {
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let hx = (v[i][j + 1] + v[i][j - 1]) * inv_dx2
      let hy = (v[i + 1][j] + v[i - 1][j]) * inv_dy2
      let hc = v[i][j] * a_diag
      lv[i][j] = hx + hy - hc
    }
  }
}

// PCG solver for the pressure Poisson system  ∇²p = b.
// Works matrix-free via laplacian_apply.  Returns the number of PCG iterations
// actually performed (≤ pcg_max_iter).
fn pressure_poisson_pcg(p : Array[Array[Double]], dx : Double, dy : Double,
                        b : Array[Array[Double]]) -> Int {
  let inv_dx2 = 1.0 / (dx * dx)
  let inv_dy2 = 1.0 / (dy * dy)
  let a_diag  = 2.0 * inv_dx2 + 2.0 * inv_dy2
  let inv_m   = 1.0 / a_diag  // Jacobi: M = diag(A) → M⁻¹r = r / a_diag

  // Working arrays (interior values only; boundary rows/cols used as ghost storage)
  let r  = create_zeros_2d(ny, nx)  // residual
  let d  = create_zeros_2d(ny, nx)  // search direction
  let ad = create_zeros_2d(ny, nx)  // A·d (matrix-vector product)

  // r₀ = b − ∇²p₀;  apply BCs to p₀ first so ghost values are consistent
  apply_pressure_bcs(p)
  laplacian_apply(p, ad, inv_dx2, inv_dy2, a_diag)

  let mut b_sq = 0.0
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      r[i][j] = b[i][j] - ad[i][j]
      b_sq = b_sq + b[i][j] * b[i][j]
    }
  }
  let b_norm = b_sq.sqrt()
  // Trivial RHS: no solve needed
  if b_norm < 1.0e-15 {
    apply_pressure_bcs(p)
    return 0
  }

  // d₀ = z₀ = M⁻¹ r₀;  ρ₀ = r₀ᵀ z₀
  let mut rho = 0.0
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let zi = r[i][j] * inv_m
      d[i][j] = zi
      rho = rho + r[i][j] * zi
    }
  }

  let mut iter_done = 0
  for iter = 0; iter < pcg_max_iter; iter = iter + 1 {
    // q = A dₖ  (apply BCs to d before stencil so ghost cells are correct)
    apply_pressure_bcs(d)
    laplacian_apply(d, ad, inv_dx2, inv_dy2, a_diag)

    // αₖ = ρₖ / (dₖᵀ q)
    let mut dAd = 0.0
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        dAd = dAd + d[i][j] * ad[i][j]
      }
    }
    // Guard: if search direction is already in kernel, stop
    if dAd.abs() < 1.0e-15 { break }
    let alpha = rho / dAd

    // x ← x + α d;  r ← r − α q;  accumulate ‖r‖²
    let mut r_sq = 0.0
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        p[i][j] = p[i][j] + alpha * d[i][j]
        let r_new = r[i][j] - alpha * ad[i][j]
        r[i][j]  = r_new
        r_sq = r_sq + r_new * r_new
      }
    }
    iter_done = iter + 1

    // Convergence check: ‖r‖ / ‖b‖ < pcg_tol
    if r_sq.sqrt() < pcg_tol * b_norm { break }

    // ρ_{k+1} = r_{k+1}ᵀ M⁻¹ r_{k+1}
    let mut rho_new = 0.0
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        rho_new = rho_new + r[i][j] * r[i][j] * inv_m
      }
    }
    // Guard: stagnated
    if rho.abs() < 1.0e-15 { break }
    let beta = rho_new / rho
    rho = rho_new

    // d_{k+1} = M⁻¹ r_{k+1} + β dₖ
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        d[i][j] = r[i][j] * inv_m + beta * d[i][j]
      }
    }
  }

  apply_pressure_bcs(p)
  iter_done
}

// ── [Layer 2 ext] Additional PCG Preconditioners ──────────────────────────────
//
// Supplements the existing Jacobi (Diagonal) preconditioner with three
// alternatives: DILU, DIC, and GAMG.  All are accessed via:
//   pressure_poisson_pcg_prec(p, dx, dy, b, precond_type)
// where precond_type: 0=Jacobi  1=DILU  2=DIC  3=GAMG
//
// The original pressure_poisson_pcg() is NOT modified.
//
// References:
//   DILU/DIC : OpenFOAM-dev DILUPreconditioner.C, DICPreconditioner.C (GPL-3.0)
//              https://github.com/OpenFOAM/OpenFOAM-dev
//   GAMG     : Briggs, Henson & McCormick (2000). A Multigrid Tutorial. SIAM.
//              Trottenberg, Oosterlee & Schüller (2001). Multigrid. Academic Press.
//   IC(0)    : Meijerink & van der Vorst (1977). Math. Comp. 31(137).
//              Kershaw (1978). J. Comput. Phys. 26(1).
//
// See docs/preconditioner_theory.md for full mathematical derivations.

// ── A.1  Modified diagonal (shared setup for both DILU and DIC) ───────────────
//
// Computes the IC(0) modified diagonal for the 5-point Laplacian:
//   d[i][j] = a_diag − (inv_dx2)²/d[i][j−1] − (inv_dy2)²/d[i−1][j]
//
// Corresponds to the L·D·L^T factorisation of M = −A (the SPD form).
// Row-major ordering: west (j−1) and south (i−1) neighbours precede (i,j).
// Safety guard: if d drops to ≤ 1e-15, fall back to a_diag (Jacobi level).
fn build_modified_diag(
  inv_dx2 : Double,
  inv_dy2 : Double,
  a_diag  : Double,
) -> Array[Array[Double]] {
  let d = create_zeros_2d(ny, nx)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let west  = if j > 1 { inv_dx2 * inv_dx2 / d[i][j - 1] } else { 0.0 }
      let south = if i > 1 { inv_dy2 * inv_dy2 / d[i - 1][j] } else { 0.0 }
      let dval  = a_diag - west - south
      d[i][j] = if dval > 1.0e-15 { dval } else { a_diag }
    }
  }
  d
}

// ── A.2  DILU preconditioner – apply step ─────────────────────────────────────
//
// M_DILU⁻¹ r = z :   z[i][j] = r[i][j] * d_inv[i][j]
// (Diagonal scaling with modified diagonal; no triangular sweeps.)
fn apply_dilu_precond(
  r     : Array[Array[Double]],
  z     : Array[Array[Double]],
  d_inv : Array[Array[Double]],
) -> Unit {
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      z[i][j] = r[i][j] * d_inv[i][j]
    }
  }
}

// ── A.3  DIC preconditioner – apply step ──────────────────────────────────────
//
// Applies M_DIC⁻¹ r = z via L·D·L^T  (IC(0) Incomplete Cholesky):
//
// Step 1 – Forward sweep  L·w = r  (row-major order, (1,1)→(ny-2,nx-2)):
//   w[i][j] = r[i][j] + (inv_dx2/d[i][j-1])·w[i][j-1]
//                      + (inv_dy2/d[i-1][j])·w[i-1][j]
//
// Step 2 – Diagonal scale  D·y = w:
//   y[i][j] = w[i][j] / d[i][j]          (result stored in z)
//
// Step 3 – Backward sweep  L^T·z = y  (reverse row-major, (ny-2,nx-2)→(1,1)):
//   z[i][j] = y[i][j] + (inv_dx2/d[i][j])·z[i][j+1]
//                      + (inv_dy2/d[i][j])·z[i+1][j]
//
// Reverse order is achieved with auxiliary counters ri,ci to avoid
// reliance on decrement-step for-loops.
fn apply_dic_precond(
  r       : Array[Array[Double]],
  z       : Array[Array[Double]],
  d       : Array[Array[Double]],
  inv_dx2 : Double,
  inv_dy2 : Double,
) -> Unit {
  let w = create_zeros_2d(ny, nx)

  // Step 1: Forward sweep  L · w = r
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let west  = if j > 1 { inv_dx2 / d[i][j - 1] * w[i][j - 1] } else { 0.0 }
      let south = if i > 1 { inv_dy2 / d[i - 1][j] * w[i - 1][j] } else { 0.0 }
      w[i][j] = r[i][j] + west + south
    }
  }

  // Step 2: Diagonal scale  D · y = w  (write into z for reuse)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      z[i][j] = w[i][j] / d[i][j]
    }
  }

  // Step 3: Backward sweep  L^T · z = y  (reverse row-major via auxiliary index)
  for ri = 0; ri < ny - 2; ri = ri + 1 {
    let i = ny - 2 - ri
    for ci = 0; ci < nx - 2; ci = ci + 1 {
      let j     = nx - 2 - ci
      let east  = if j < nx - 2 { inv_dx2 / d[i][j] * z[i][j + 1] } else { 0.0 }
      let north = if i < ny - 2 { inv_dy2 / d[i][j] * z[i + 1][j] } else { 0.0 }
      z[i][j] = z[i][j] + east + north
    }
  }
}

// ── A.4  GAMG (Geometric-Algebraic Multigrid) preconditioner ──────────────────
//
// 2-level V-cycle used as a PCG preconditioner.
// Fine:   41×41 nodes (interior 39×39)
// Coarse: 21×21 nodes (interior 19×19, every-other-point coarsening)
//
// V-cycle outline:
//   1. Pre-smooth   (ν₁=2 damped Jacobi, ω=2/3)
//   2. Fine residual  res_f = r − A·z
//   3. Restrict      r_c = R · res_f          (injection)
//   4. Coarse solve  A_c · e_c = r_c          (20 Jacobi steps)
//   5. Prolongate    z ← z + P · e_c          (bilinear)
//   6. Post-smooth   (ν₂=2 damped Jacobi)

/// Coarse grid node count (both dimensions) for the GAMG V-cycle.
let gamg_nc : Int = (nx + 1) / 2   // = 21 for nx = 41

// Apply cavity pressure BCs on an arbitrary n×n grid.
// Same BC types as the fine grid: Neumann left/right/bottom, Dirichlet top (p=0).
fn apply_pressure_bcs_n(p : Array[Array[Double]], n : Int) -> Unit {
  for i = 0; i < n; i = i + 1 {
    p[i][0]     = p[i][1]       // left  Neumann
    p[i][n - 1] = p[i][n - 2]  // right Neumann
  }
  for j = 0; j < n; j = j + 1 {
    p[0][j]     = p[1][j]       // bottom Neumann
    p[n - 1][j] = 0.0           // top lid Dirichlet p = 0
  }
}

// Full-weighting restriction (normalised).  Raw P^T weights for an interior
// coarse node sum to 4 (1 + 4×½ + 4×¼), so we divide by 4 to produce a
// weighted average.  Without normalisation the coarse operator over-amplifies
// smooth modes by 4×, causing alpha ≈ −¼ and stalled PCG convergence.
// Boundary terms (fine nodes outside grid) are silently omitted.
fn gamg_restrict(
  r_fine   : Array[Array[Double]],
  r_coarse : Array[Array[Double]],
) -> Unit {
  for ci = 0; ci < gamg_nc; ci = ci + 1 {
    for cj = 0; cj < gamg_nc; cj = cj + 1 {
      let fi   = 2 * ci
      let fj   = 2 * cj
      let ctr  = r_fine[fi][fj]
      let w    = if fj > 0      { r_fine[fi][fj - 1] * 0.5 } else { 0.0 }
      let e    = if fj < nx - 1 { r_fine[fi][fj + 1] * 0.5 } else { 0.0 }
      let s    = if fi > 0      { r_fine[fi - 1][fj] * 0.5 } else { 0.0 }
      let n    = if fi < ny - 1 { r_fine[fi + 1][fj] * 0.5 } else { 0.0 }
      let sw_v = if fi > 0      && fj > 0      { r_fine[fi - 1][fj - 1] * 0.25 } else { 0.0 }
      let se_v = if fi > 0      && fj < nx - 1 { r_fine[fi - 1][fj + 1] * 0.25 } else { 0.0 }
      let nw_v = if fi < ny - 1 && fj > 0      { r_fine[fi + 1][fj - 1] * 0.25 } else { 0.0 }
      let ne_v = if fi < ny - 1 && fj < nx - 1 { r_fine[fi + 1][fj + 1] * 0.25 } else { 0.0 }
      // Normalise by 4 (interior weight sum) so R is a weighted average.
      // Without this factor the coarse correction over-amplifies smooth modes
      // by 4×, making alpha ≈ −¼ instead of −1 and stalling PCG.
      r_coarse[ci][cj] = (ctr + w + e + s + n + sw_v + se_v + nw_v + ne_v) / 4.0
    }
  }
}

// Bilinear prolongation: e_coarse (21×21) → e_fine (41×41).
// Four node-type cases (see docs/preconditioner_theory.md §6.5).
fn gamg_prolongate(
  e_coarse : Array[Array[Double]],
  e_fine   : Array[Array[Double]],
) -> Unit {
  let nc = gamg_nc
  // Zero fine grid
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      e_fine[i][j] = 0.0
    }
  }
  // Case 1: coarse-coincident (even i, even j)
  for ci = 0; ci < nc; ci = ci + 1 {
    for cj = 0; cj < nc; cj = cj + 1 {
      e_fine[2 * ci][2 * cj] = e_coarse[ci][cj]
    }
  }
  // Case 2: horizontal midpoint (even i, odd j)
  for ci = 0; ci < nc; ci = ci + 1 {
    for cj = 0; cj < nc - 1; cj = cj + 1 {
      e_fine[2 * ci][2 * cj + 1] = (e_coarse[ci][cj] + e_coarse[ci][cj + 1]) * 0.5
    }
  }
  // Case 3: vertical midpoint (odd i, even j)
  for ci = 0; ci < nc - 1; ci = ci + 1 {
    for cj = 0; cj < nc; cj = cj + 1 {
      e_fine[2 * ci + 1][2 * cj] = (e_coarse[ci][cj] + e_coarse[ci + 1][cj]) * 0.5
    }
  }
  // Case 4: cell centre (odd i, odd j)
  for ci = 0; ci < nc - 1; ci = ci + 1 {
    for cj = 0; cj < nc - 1; cj = cj + 1 {
      let avg = (e_coarse[ci][cj] + e_coarse[ci][cj + 1] +
                 e_coarse[ci + 1][cj] + e_coarse[ci + 1][cj + 1]) * 0.25
      e_fine[2 * ci + 1][2 * cj + 1] = avg
    }
  }
}

// Damped Jacobi smoother on the fine grid for the SPD system B·z = r (B = −A):
//   z ← z + (ω / a_diag) · (r + A·z),   ω = 2/3
//
// Sign convention: the discrete Laplacian A is SND.  The V-cycle works with
// the SPD form B = −A throughout.  The Jacobi update for B·z = r is:
//   z ← z + ω·diag(B)⁻¹·(r − B·z)
//         = z + ω/a_diag · (r − (−A)·z)
//         = z + ω/a_diag · (r + A·z)       ← note the PLUS sign
// Spectral radius: max |1 − ω·μ_B/a_diag| = max(1−ω, 1) = 1  (no divergence).
// High-frequency components (μ_B ≈ a_diag) decay by factor (1−ω) = 1/3.
fn gamg_smooth_fine(
  z       : Array[Array[Double]],
  r       : Array[Array[Double]],
  inv_dx2 : Double,
  inv_dy2 : Double,
  a_diag  : Double,
  nu      : Int,
) -> Unit {
  let damp = 2.0 / (3.0 * a_diag)
  let az   = create_zeros_2d(ny, nx)
  for s = 0; s < nu; s = s + 1 {
    apply_pressure_bcs(z)
    laplacian_apply(z, az, inv_dx2, inv_dy2, a_diag)
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        z[i][j] = z[i][j] + damp * (r[i][j] + az[i][j])
      }
    }
  }
}

// Coarse-grid CG solve for the SPD system  B_c · e_c = r_c  (B_c = −A_c).
// Damped Jacobi (ω=2/3) has spectral radius 1 on smooth modes — it cannot
// reduce the low-frequency error that the V-cycle needs the coarse grid to
// handle.  CG converges in O(√κ_c) ≈ 15-20 steps on this 21×21 grid.
//
// Start from e_c = 0 (caller must zero e_c before the call).
fn gamg_coarse_cg(
  e_c       : Array[Array[Double]],
  r_c       : Array[Array[Double]],
  inv_dx2_c : Double,
  inv_dy2_c : Double,
  a_diag_c  : Double,
) -> Unit {
  let nc  = gamg_nc
  let res = create_zeros_2d(nc, nc)
  let d_c = create_zeros_2d(nc, nc)
  let q   = create_zeros_2d(nc, nc)

  // Initial residual = r_c (e_c = 0); d_0 = res_0
  let mut b_sq = 0.0
  for i = 1; i < nc - 1; i = i + 1 {
    for j = 1; j < nc - 1; j = j + 1 {
      let rv = r_c[i][j]
      res[i][j] = rv
      d_c[i][j] = rv
      b_sq = b_sq + rv * rv
    }
  }
  let b_norm = b_sq.sqrt()
  if b_norm < 1.0e-15 { return }

  let mut rho = b_sq   // unpreconditioned: rho = res^T · res

  // CG on SPD B_c · e_c = r_c; at most nc*nc iterations (exact in exact arith)
  for iter = 0; iter < nc * nc; iter = iter + 1 {
    // q = B_c · d_c = −A_c · d_c
    apply_pressure_bcs_n(d_c, nc)
    for i = 1; i < nc - 1; i = i + 1 {
      for j = 1; j < nc - 1; j = j + 1 {
        let hx = (d_c[i][j + 1] + d_c[i][j - 1]) * inv_dx2_c
        let hy = (d_c[i + 1][j] + d_c[i - 1][j]) * inv_dy2_c
        let az = hx + hy - d_c[i][j] * a_diag_c
        q[i][j] = -az   // B_c · d = −A_c · d
      }
    }

    // alpha = rho / (d^T q)   — positive because B_c is SPD
    let mut dBd = 0.0
    for i = 1; i < nc - 1; i = i + 1 {
      for j = 1; j < nc - 1; j = j + 1 {
        dBd = dBd + d_c[i][j] * q[i][j]
      }
    }
    if dBd.abs() < 1.0e-30 { break }
    let alpha = rho / dBd

    // e_c += alpha·d;  res -= alpha·q
    let mut r_sq = 0.0
    for i = 1; i < nc - 1; i = i + 1 {
      for j = 1; j < nc - 1; j = j + 1 {
        e_c[i][j] = e_c[i][j] + alpha * d_c[i][j]
        let r_new = res[i][j] - alpha * q[i][j]
        res[i][j] = r_new
        r_sq = r_sq + r_new * r_new
      }
    }
    if r_sq.sqrt() < pcg_tol * b_norm { break }

    let rho_new = r_sq
    if rho.abs() < 1.0e-30 { break }
    let beta = rho_new / rho
    rho = rho_new

    // d = res + beta·d
    for i = 1; i < nc - 1; i = i + 1 {
      for j = 1; j < nc - 1; j = j + 1 {
        d_c[i][j] = res[i][j] + beta * d_c[i][j]
      }
    }
  }
  apply_pressure_bcs_n(e_c, nc)
}

// GAMG V-cycle: given fine-grid residual r, compute correction z ≈ A⁻¹ r.
fn apply_gamg_precond(
  r       : Array[Array[Double]],
  z       : Array[Array[Double]],
  inv_dx2 : Double,
  inv_dy2 : Double,
  a_diag  : Double,
) -> Unit {
  let nc        = gamg_nc
  let inv_dx2_c = inv_dx2 / 4.0   // coarse spacing: dx_c = 2·dx
  let inv_dy2_c = inv_dy2 / 4.0
  let a_diag_c  = 2.0 * inv_dx2_c + 2.0 * inv_dy2_c

  let res_f = create_zeros_2d(ny, nx)
  let r_c   = create_zeros_2d(nc, nc)
  let e_c   = create_zeros_2d(nc, nc)
  let pe    = create_zeros_2d(ny, nx)
  let tmp   = create_zeros_2d(ny, nx)

  // Initialise z = 0 at interior nodes
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      z[i][j] = 0.0
    }
  }

  // 1. Pre-smooth  (ν₁ = 2 steps)
  gamg_smooth_fine(z, r, inv_dx2, inv_dy2, a_diag, 2)

  // 2. Fine residual: res_f = r − B·z1 = r + A·z1  (B = −A is SPD)
  apply_pressure_bcs(z)
  laplacian_apply(z, tmp, inv_dx2, inv_dy2, a_diag)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      res_f[i][j] = r[i][j] + tmp[i][j]
    }
  }

  // 3. Restrict  r_c = R · res_f  (injection)
  gamg_restrict(res_f, r_c)

  // 4. Coarse CG solve: B_c · e_c = r_c  (start from e_c = 0)
  gamg_coarse_cg(e_c, r_c, inv_dx2_c, inv_dy2_c, a_diag_c)

  // 5. Prolongate and add coarse correction
  gamg_prolongate(e_c, pe)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      z[i][j] = z[i][j] + pe[i][j]
    }
  }

  // 6. Post-smooth  (ν₂ = 2 steps)
  gamg_smooth_fine(z, r, inv_dx2, inv_dy2, a_diag, 2)
}

// ── A.5  Generic PCG with selectable preconditioner ───────────────────────────
//
// precond_type:  0 = Jacobi (equivalent to pressure_poisson_pcg)
//                1 = DILU   (modified-diagonal scaling)
//                2 = DIC    (IC(0) with forward/backward sweeps)
//                3 = GAMG   (2-level V-cycle)
//
// Returns the number of PCG iterations performed (≤ pcg_max_iter).
// The original pressure_poisson_pcg() is NOT called here; this is a parallel
// implementation so the existing function remains byte-for-byte unchanged.
fn pressure_poisson_pcg_prec(
  p            : Array[Array[Double]],
  dx_          : Double,
  dy_          : Double,
  b            : Array[Array[Double]],
  precond_type : Int,
) -> Int {
  let inv_dx2 = 1.0 / (dx_ * dx_)
  let inv_dy2 = 1.0 / (dy_ * dy_)
  let a_diag  = 2.0 * inv_dx2 + 2.0 * inv_dy2
  let inv_m   = 1.0 / a_diag   // Jacobi scalar and GAMG smoothing denom

  // Build modified diagonal for DILU (type 1) and DIC (type 2).
  // For Jacobi and GAMG, allocate a dummy zero array (never accessed).
  let d_mod = if precond_type == 1 || precond_type == 2 {
    build_modified_diag(inv_dx2, inv_dy2, a_diag)
  } else {
    create_zeros_2d(ny, nx)
  }

  // Precompute element-wise inverse for DILU (avoid repeated division).
  let d_inv = create_zeros_2d(ny, nx)
  if precond_type == 1 {
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let dv    = d_mod[i][j]
        d_inv[i][j] = if dv > 1.0e-15 { 1.0 / dv } else { inv_m }
      }
    }
  }

  let r  = create_zeros_2d(ny, nx)
  let d  = create_zeros_2d(ny, nx)
  let ad = create_zeros_2d(ny, nx)
  let z  = create_zeros_2d(ny, nx)

  // r₀ = b − A·p₀
  apply_pressure_bcs(p)
  laplacian_apply(p, ad, inv_dx2, inv_dy2, a_diag)
  let mut b_sq = 0.0
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      r[i][j] = b[i][j] - ad[i][j]
      b_sq    = b_sq + b[i][j] * b[i][j]
    }
  }
  let b_norm = b_sq.sqrt()
  if b_norm < 1.0e-15 {
    apply_pressure_bcs(p)
    return 0
  }

  // z₀ = M⁻¹ r₀
  if precond_type == 1 {
    apply_dilu_precond(r, z, d_inv)
  } else if precond_type == 2 {
    apply_dic_precond(r, z, d_mod, inv_dx2, inv_dy2)
  } else if precond_type == 3 {
    apply_gamg_precond(r, z, inv_dx2, inv_dy2, a_diag)
  } else {
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        z[i][j] = r[i][j] * inv_m
      }
    }
  }

  // d₀ = z₀;  ρ₀ = r₀ᵀ z₀
  let mut rho = 0.0
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      d[i][j] = z[i][j]
      rho     = rho + r[i][j] * z[i][j]
    }
  }

  let mut iter_done = 0
  for iter = 0; iter < pcg_max_iter; iter = iter + 1 {
    // q = A · dₖ
    apply_pressure_bcs(d)
    laplacian_apply(d, ad, inv_dx2, inv_dy2, a_diag)

    // αₖ = ρₖ / (dₖᵀ q)
    let mut dAd = 0.0
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        dAd = dAd + d[i][j] * ad[i][j]
      }
    }
    if dAd.abs() < 1.0e-15 { break }
    let alpha = rho / dAd

    // p ← p + α·d;   r ← r − α·q;   accumulate ‖r‖²
    let mut r_sq = 0.0
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        p[i][j]   = p[i][j] + alpha * d[i][j]
        let r_new = r[i][j] - alpha * ad[i][j]
        r[i][j]   = r_new
        r_sq      = r_sq + r_new * r_new
      }
    }
    iter_done = iter + 1
    if r_sq.sqrt() < pcg_tol * b_norm { break }

    // z_{k+1} = M⁻¹ r_{k+1}
    if precond_type == 1 {
      apply_dilu_precond(r, z, d_inv)
    } else if precond_type == 2 {
      apply_dic_precond(r, z, d_mod, inv_dx2, inv_dy2)
    } else if precond_type == 3 {
      apply_gamg_precond(r, z, inv_dx2, inv_dy2, a_diag)
    } else {
      for i = 1; i < ny - 1; i = i + 1 {
        for j = 1; j < nx - 1; j = j + 1 {
          z[i][j] = r[i][j] * inv_m
        }
      }
    }

    // ρ_{k+1} = r_{k+1}ᵀ z_{k+1}
    let mut rho_new = 0.0
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        rho_new = rho_new + r[i][j] * z[i][j]
      }
    }
    if rho.abs() < 1.0e-15 { break }
    let beta = rho_new / rho
    rho = rho_new

    // d_{k+1} = z_{k+1} + β·dₖ
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        d[i][j] = z[i][j] + beta * d[i][j]
      }
    }
  }

  apply_pressure_bcs(p)
  iter_done
}

// ── A.6  Named wrappers for each preconditioner ────────────────────────────────

/// PCG pressure solve with DILU (modified-diagonal) preconditioner.
fn pressure_poisson_pcg_dilu(
  p   : Array[Array[Double]],
  dx_ : Double,
  dy_ : Double,
  b   : Array[Array[Double]],
) -> Int {
  pressure_poisson_pcg_prec(p, dx_, dy_, b, 1)
}

/// PCG pressure solve with DIC (IC(0) Incomplete Cholesky) preconditioner.
fn pressure_poisson_pcg_dic(
  p   : Array[Array[Double]],
  dx_ : Double,
  dy_ : Double,
  b   : Array[Array[Double]],
) -> Int {
  pressure_poisson_pcg_prec(p, dx_, dy_, b, 2)
}

/// Stationary V-cycle iteration for the pressure Poisson system ∇²p = b.
/// Each step: r = b − A·p,  z = V-cycle(r),  p -= z.
///
/// Sign analysis: the V-cycle solves B·z = r where B = −A (SPD), so
/// z ≈ (−A)^{−1}·r = −A^{−1}·r.  The corrected Richardson iteration is:
///   p_{k+1} = p_k − T·r_k   (T = (−A)^{−1})
/// Error propagation: e_{k+1} = (I + T·A)·e_k → 0 for exact T.  Note the
/// MINUS sign: p += z would give spectral radius 2 (diverges).
///
/// Uses stationary form instead of PCG because the convergence-based coarse
/// CG inside apply_gamg_precond is non-linear and would break PCG
/// orthogonality. The stationary form converges with any consistent T.
/// Returns the number of V-cycle applications (0 if b ≡ 0).
fn pressure_poisson_pcg_gamg(
  p   : Array[Array[Double]],
  dx_ : Double,
  dy_ : Double,
  b   : Array[Array[Double]],
) -> Int {
  let inv_dx2 = 1.0 / (dx_ * dx_)
  let inv_dy2 = 1.0 / (dy_ * dy_)
  let a_diag  = 2.0 * inv_dx2 + 2.0 * inv_dy2
  // Early-exit for trivial RHS (avoids divide-by-zero in convergence check)
  let mut b_sq = 0.0
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      b_sq = b_sq + b[i][j] * b[i][j]
    }
  }
  let b_norm = b_sq.sqrt()
  if b_norm < 1.0e-15 {
    apply_pressure_bcs(p)
    return 0
  }
  let r  = create_zeros_2d(ny, nx)
  let z  = create_zeros_2d(ny, nx)
  let ap = create_zeros_2d(ny, nx)
  let mut iter_done = 0
  for iter = 0; iter < pcg_max_iter; iter = iter + 1 {
    // r = b − A·p
    apply_pressure_bcs(p)
    laplacian_apply(p, ap, inv_dx2, inv_dy2, a_diag)
    let mut r_sq = 0.0
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        r[i][j] = b[i][j] - ap[i][j]
        r_sq    = r_sq + r[i][j] * r[i][j]
      }
    }
    iter_done = iter + 1
    if r_sq.sqrt() < pcg_tol * b_norm { break }
    // z = V-cycle(r):  z ≈ (−A)^{−1} r  (V-cycle solves B·z = r, B = −A SPD)
    // Correct update: p -= z  (subtract, not add)
    // Proof: e_{k+1} = (I + T·A)·e_k with T = (−A)^{−1} gives I − I = 0 ✓
    apply_gamg_precond(r, z, inv_dx2, inv_dy2, a_diag)
    // p -= z  (stationary Richardson: p_{k+1} = p_k − T·(b−A·p_k))
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        p[i][j] = p[i][j] - z[i][j]
      }
    }
  }
  apply_pressure_bcs(p)
  iter_done
}

// ── [Layer 1] Chorin projection method using PCG for the pressure solve ───────
//
// Identical algorithm to cavity_flow_array (Chorin 1968) but the inner pressure
// solve uses pressure_poisson_pcg instead of pressure_poisson_array (GS).
// The `pcg_iters` array is updated each step with the PCG iteration count.
fn cavity_flow_pcg(
  nt_steps  : Int,
  u         : Array[Array[Double]],
  v         : Array[Array[Double]],
  dt_       : Double,
  dx_       : Double,
  dy_       : Double,
  p         : Array[Array[Double]],
  rho_      : Double,
  nu_       : Double,
  pcg_iters : Array[Int],
) -> (Array[Array[Double]], Array[Array[Double]], Array[Array[Double]]) {
  let un = create_zeros_2d(ny, nx)
  let vn = create_zeros_2d(ny, nx)
  let b  = create_zeros_2d(ny, nx)

  for n = 0; n < nt_steps; n = n + 1 {
    copy_2d_array(u, un)
    copy_2d_array(v, vn)

    build_up_b_array(b, rho_, dt_, u, v, dx_, dy_) |> ignore

    // PCG pressure solve (replaces Gauss-Seidel)
    let iters = pressure_poisson_pcg(p, dx_, dy_, b)
    pcg_iters[0] = iters

    // Explicit velocity update – identical to Chorin
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let conv_u_x = un[i][j] * dt_ / dx_ * (un[i][j] - un[i][j - 1])
        let conv_u_y = vn[i][j] * dt_ / dy_ * (un[i][j] - un[i - 1][j])
        let pg_u     = dt_ / (2.0 * rho_ * dx_) * (p[i][j + 1] - p[i][j - 1])
        let visc_u_x = nu_ * dt_ / (dx_ * dx_) * (un[i][j + 1] - 2.0 * un[i][j] + un[i][j - 1])
        let visc_u_y = nu_ * dt_ / (dy_ * dy_) * (un[i + 1][j] - 2.0 * un[i][j] + un[i - 1][j])
        let visc_u   = visc_u_x + visc_u_y
        u[i][j] = un[i][j] - conv_u_x - conv_u_y - pg_u + visc_u
      }
    }
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let conv_v_x = un[i][j] * dt_ / dx_ * (vn[i][j] - vn[i][j - 1])
        let conv_v_y = vn[i][j] * dt_ / dy_ * (vn[i][j] - vn[i - 1][j])
        let pg_v     = dt_ / (2.0 * rho_ * dy_) * (p[i + 1][j] - p[i - 1][j])
        let visc_v_x = nu_ * dt_ / (dx_ * dx_) * (vn[i][j + 1] - 2.0 * vn[i][j] + vn[i][j - 1])
        let visc_v_y = nu_ * dt_ / (dy_ * dy_) * (vn[i + 1][j] - 2.0 * vn[i][j] + vn[i - 1][j])
        let visc_v   = visc_v_x + visc_v_y
        v[i][j] = vn[i][j] - conv_v_x - conv_v_y - pg_v + visc_v
      }
    }

    // Velocity BCs: walls first, lid last (corner convention)
    for j = 0; j < nx; j = j + 1 { u[0][j] = 0.0 }
    for i = 0; i < ny; i = i + 1 {
      u[i][0]      = 0.0
      u[i][nx - 1] = 0.0
    }
    for j = 0; j < nx; j = j + 1 { u[ny - 1][j] = 1.0 }  // lid – applied last

    for j = 0; j < nx; j = j + 1 {
      v[0][j]      = 0.0
      v[ny - 1][j] = 0.0
    }
    for i = 0; i < ny; i = i + 1 {
      v[i][0]      = 0.0
      v[i][nx - 1] = 0.0
    }

    if (n + 1) % 10 == 0 {
      println("PCG step \{n + 1}/\{nt_steps}: pressure iters=\{iters}")
    }
  }
  (u, v, p)
}

// ── Global Chorin-PCG state arrays ────────────────────────────────────────────
let g_u_pcg : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 { a[i] = Array::make(nx, 0.0) }
  a
}
let g_v_pcg : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 { a[i] = Array::make(nx, 0.0) }
  a
}
let g_p_pcg : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 { a[i] = Array::make(nx, 0.0) }
  a
}
let g_steps_pcg      : Array[Int] = [0]
let g_pcg_last_iters : Array[Int] = [0]  // PCG iters used in the most recent pressure solve

// ── WASM API for Chorin-PCG solver ────────────────────────────────────────────

/// Reset Chorin-PCG state to zero; call once before the first run_chorin_pcg_n_steps().
pub fn init_chorin_pcg() -> Unit {
  g_steps_pcg[0]      = 0
  g_pcg_last_iters[0] = 0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u_pcg[i][j] = 0.0
      g_v_pcg[i][j] = 0.0
      g_p_pcg[i][j] = 0.0
    }
  }
}

/// Run n Chorin-PCG time steps starting from the current state.
pub fn run_chorin_pcg_n_steps(n : Int) -> Unit {
  let (u_out, v_out, p_out) = cavity_flow_pcg(
    n, g_u_pcg, g_v_pcg, dt, dx, dy, g_p_pcg, rho, nu, g_pcg_last_iters,
  )
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u_pcg[i][j] = u_out[i][j]
      g_v_pcg[i][j] = v_out[i][j]
      g_p_pcg[i][j] = p_out[i][j]
    }
  }
  g_steps_pcg[0] = g_steps_pcg[0] + n
}

/// Return the number of Chorin-PCG time steps completed since init_chorin_pcg().
pub fn get_pcg_step_count() -> Int { g_steps_pcg[0] }

/// Return the PCG iteration count used in the most recently completed pressure solve.
pub fn get_pcg_last_iters() -> Int { g_pcg_last_iters[0] }

/// Read PCG u-velocity at grid index (i, j).
pub fn get_u_pcg_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_u_pcg[i][j] } else { 0.0 }
}

/// Read PCG v-velocity at grid index (i, j).
pub fn get_v_pcg_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_v_pcg[i][j] } else { 0.0 }
}

/// Read PCG pressure at grid index (i, j).
pub fn get_p_pcg_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_p_pcg[i][j] } else { 0.0 }
}

/// Return velocity magnitude sqrt(u²+v²) for the PCG field at (i, j).
pub fn get_velocity_magnitude_pcg_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx {
    let u = g_u_pcg[i][j]
    let v = g_v_pcg[i][j]
    (u * u + v * v).sqrt()
  } else { 0.0 }
}

/// Return maximum |u| in the PCG velocity field.
pub fn get_max_u_pcg() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let v = g_u_pcg[i][j].abs()
      if v > m { m = v }
    }
  }
  m
}

/// Return maximum |v| in the PCG velocity field.
pub fn get_max_v_pcg() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let v = g_v_pcg[i][j].abs()
      if v > m { m = v }
    }
  }
  m
}

/// Return maximum pressure in the PCG field.
pub fn get_max_p_pcg() -> Double {
  let mut m = g_p_pcg[0][0]
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      if g_p_pcg[i][j] > m { m = g_p_pcg[i][j] }
    }
  }
  m
}

/// Return minimum pressure in the PCG field.
pub fn get_min_p_pcg() -> Double {
  let mut m = g_p_pcg[0][0]
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      if g_p_pcg[i][j] < m { m = g_p_pcg[i][j] }
    }
  }
  m
}

/// Return mean |∂u/∂x + ∂v/∂y| for the PCG velocity field.
pub fn get_pcg_divergence_norm() -> Double {
  let mut sum = 0.0
  let count = (ny - 2) * (nx - 2)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let div_x = (g_u_pcg[i][j + 1] - g_u_pcg[i][j - 1]) / (2.0 * dx)
      let div_y = (g_v_pcg[i + 1][j] - g_v_pcg[i - 1][j]) / (2.0 * dy)
      sum = sum + (div_x + div_y).abs()
    }
  }
  if count > 0 { sum / count.to_double() } else { 0.0 }
}

// ══════════════════════════════════════════════════════════════════════════════
// Phase 2 – Staggered MAC grid with PCG pressure solver
// (Harlow & Welch 1965)
//
// Grid layout  (mac_nc = nx−1 = 40 cells per direction):
//   p[i][j]   cell centre  y=(i+0.5)*dy, x=(j+0.5)*dx    mac_nc × mac_nc
//   u[i][j]   x-face       y=(i+0.5)*dy, x=j*dx          mac_nc × (mac_nc+1)
//   v[i][j]   y-face       y=i*dy,       x=(j+0.5)*dx    (mac_nc+1) × mac_nc
//
// Wall BCs:
//   u[i][0] = u[i][mac_nc] = 0            (left/right walls, all rows)
//   v[0][j] = v[mac_nc][j] = 0            (bottom/top walls, all cols)
//   Ghost for lid tangential BC:  u_above at i=mac_nc-1 = 2·1 − u[mac_nc-1][j]
//   Ghost for no-slip bottom:      u_below at i=0       = −u[0][j]
//   Ghost for no-slip sides (v):   v_right at j=mac_nc-1 = −v[i][j]
// ══════════════════════════════════════════════════════════════════════════════

/// Number of MAC cells per direction (= nx−1 = 40).
let mac_nc : Int = nx - 1

/// Whether to run the MAC solver in the local `moon run` workflow.
let run_mac : Bool = true

/// Number of MAC time steps to execute in the local workflow.
let local_mac_nt : Int = nt

// ── Pressure BCs on mac_nc × mac_nc cell-centre grid ─────────────────────────
//   dp/dx = 0  at left/right walls  (Neumann)
//   dp/dy = 0  at bottom            (Neumann)
//   p = 0      at top lid           (Dirichlet — fixes pressure reference)
//
// Note: the Dirichlet BC at the top row means the velocity correction cannot
// fully eliminate divergence in the top-row pressure cells.  Interior cells
// (i = 1..mac_nc-2) remain divergence-free to PCG tolerance.
fn apply_pressure_bcs_mac(p : Array[Array[Double]]) -> Unit {
  for i = 0; i < mac_nc; i = i + 1 {
    p[i][0]          = p[i][1]
    p[i][mac_nc - 1] = p[i][mac_nc - 2]
  }
  for j = 0; j < mac_nc; j = j + 1 {
    p[0][j]          = p[1][j]
    p[mac_nc - 1][j] = 0.0
  }
}

// ── Matrix-free 5-point Laplacian on an nr × nc_ grid ────────────────────────
fn laplacian_apply_n(
  v       : Array[Array[Double]],
  lv      : Array[Array[Double]],
  inv_dx2 : Double,
  inv_dy2 : Double,
  a_diag  : Double,
  nr      : Int,
  nc_     : Int,
) -> Unit {
  for i = 1; i < nr - 1; i = i + 1 {
    for j = 1; j < nc_ - 1; j = j + 1 {
      let hx = (v[i][j + 1] + v[i][j - 1]) * inv_dx2
      let hy = (v[i + 1][j] + v[i - 1][j]) * inv_dy2
      let hc = v[i][j] * a_diag
      lv[i][j] = hx + hy - hc
    }
  }
}

// ── PCG solver for the MAC pressure Poisson system ───────────────────────────
fn pressure_poisson_pcg_mac(
  p   : Array[Array[Double]],
  dx_ : Double,
  dy_ : Double,
  b   : Array[Array[Double]],
) -> Int {
  let nr      = mac_nc
  let nc_     = mac_nc
  let inv_dx2 = 1.0 / (dx_ * dx_)
  let inv_dy2 = 1.0 / (dy_ * dy_)
  let a_diag  = 2.0 * inv_dx2 + 2.0 * inv_dy2
  let inv_m   = 1.0 / a_diag

  let r  = create_zeros_2d(nr, nc_)
  let d  = create_zeros_2d(nr, nc_)
  let ad = create_zeros_2d(nr, nc_)

  apply_pressure_bcs_mac(p)
  laplacian_apply_n(p, ad, inv_dx2, inv_dy2, a_diag, nr, nc_)

  let mut b_sq = 0.0
  for i = 1; i < nr - 1; i = i + 1 {
    for j = 1; j < nc_ - 1; j = j + 1 {
      r[i][j] = b[i][j] - ad[i][j]
      b_sq    = b_sq + b[i][j] * b[i][j]
    }
  }
  let b_norm = b_sq.sqrt()
  if b_norm < 1.0e-15 {
    apply_pressure_bcs_mac(p)
    return 0
  }

  let mut rho = 0.0
  for i = 1; i < nr - 1; i = i + 1 {
    for j = 1; j < nc_ - 1; j = j + 1 {
      let zi  = r[i][j] * inv_m
      d[i][j] = zi
      rho     = rho + r[i][j] * zi
    }
  }

  let mut iter_done = 0
  for iter = 0; iter < pcg_max_iter; iter = iter + 1 {
    apply_pressure_bcs_mac(d)
    laplacian_apply_n(d, ad, inv_dx2, inv_dy2, a_diag, nr, nc_)

    let mut dAd = 0.0
    for i = 1; i < nr - 1; i = i + 1 {
      for j = 1; j < nc_ - 1; j = j + 1 {
        dAd = dAd + d[i][j] * ad[i][j]
      }
    }
    if dAd.abs() < 1.0e-15 { break }
    let alpha = rho / dAd

    let mut r_sq = 0.0
    for i = 1; i < nr - 1; i = i + 1 {
      for j = 1; j < nc_ - 1; j = j + 1 {
        p[i][j]   = p[i][j] + alpha * d[i][j]
        let r_new = r[i][j] - alpha * ad[i][j]
        r[i][j]   = r_new
        r_sq      = r_sq + r_new * r_new
      }
    }
    iter_done = iter + 1
    if r_sq.sqrt() < pcg_tol * b_norm { break }

    let mut rho_new = 0.0
    for i = 1; i < nr - 1; i = i + 1 {
      for j = 1; j < nc_ - 1; j = j + 1 {
        rho_new = rho_new + r[i][j] * r[i][j] * inv_m
      }
    }
    if rho.abs() < 1.0e-15 { break }
    let beta = rho_new / rho
    rho = rho_new

    for i = 1; i < nr - 1; i = i + 1 {
      for j = 1; j < nc_ - 1; j = j + 1 {
        d[i][j] = r[i][j] * inv_m + beta * d[i][j]
      }
    }
  }
  apply_pressure_bcs_mac(p)
  iter_done
}

// ── MAC u-predictor ───────────────────────────────────────────────────────────
// Computes u* at x-faces (i=0..mac_nc-1, j=1..mac_nc-1).
// Ghost cells: bottom no-slip → u_below = −u[0][j];
//              top lid       → u_above = 2·1 − u[mac_nc-1][j].
fn mac_u_predictor(
  u   : Array[Array[Double]],
  v   : Array[Array[Double]],
  dt_ : Double,
  dx_ : Double,
  dy_ : Double,
  nu_ : Double,
  us  : Array[Array[Double]],
) -> Unit {
  let dx2   = dx_ * dx_
  let dy2   = dy_ * dy_
  let u_lid = 1.0
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 1; j < mac_nc; j = j + 1 {
      // Advection in x: (u_e² − u_w²) / dx
      let u_e    = (u[i][j] + u[i][j + 1]) / 2.0
      let u_w    = (u[i][j - 1] + u[i][j]) / 2.0
      let conv_x = dt_ / dx_ * (u_e * u_e - u_w * u_w)

      // Ghost values for viscosity and y-advection
      let u_above = if i < mac_nc - 1 { u[i + 1][j] } else { 2.0 * u_lid - u[i][j] }
      let u_below = if i > 0 { u[i - 1][j] } else { -u[i][j] }

      // Advection in y: (v_n·u_n − v_s·u_s) / dy
      let u_n    = (u[i][j] + u_above) / 2.0
      let u_s    = (u_below + u[i][j]) / 2.0
      let v_n    = (v[i + 1][j - 1] + v[i + 1][j]) / 2.0
      let v_s    = (v[i][j - 1] + v[i][j]) / 2.0
      let conv_y = dt_ / dy_ * (v_n * u_n - v_s * u_s)

      // Viscosity
      let visc_x = nu_ * dt_ / dx2 * (u[i][j + 1] - 2.0 * u[i][j] + u[i][j - 1])
      let visc_y = nu_ * dt_ / dy2 * (u_above - 2.0 * u[i][j] + u_below)

      us[i][j] = u[i][j] - conv_x - conv_y + visc_x + visc_y
    }
    us[i][0]      = 0.0
    us[i][mac_nc] = 0.0
  }
}

// ── MAC v-predictor ───────────────────────────────────────────────────────────
// Computes v* at y-faces (i=1..mac_nc-1, j=0..mac_nc-1).
// Ghost cells: left/right no-slip → v_left = −v[i][0], v_right = −v[i][mac_nc-1].
fn mac_v_predictor(
  u   : Array[Array[Double]],
  v   : Array[Array[Double]],
  dt_ : Double,
  dx_ : Double,
  dy_ : Double,
  nu_ : Double,
  vs  : Array[Array[Double]],
) -> Unit {
  let dx2 = dx_ * dx_
  let dy2 = dy_ * dy_
  for i = 1; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 {
      // Advection in y: (v_n² − v_s²) / dy
      let v_n    = (v[i][j] + v[i + 1][j]) / 2.0
      let v_s    = (v[i - 1][j] + v[i][j]) / 2.0
      let conv_y = dt_ / dy_ * (v_n * v_n - v_s * v_s)

      // Advection in x: (u_e·v_e − u_w·v_w) / dx
      let u_e    = (u[i - 1][j + 1] + u[i][j + 1]) / 2.0
      let u_w    = (u[i - 1][j] + u[i][j]) / 2.0
      let v_e    = if j < mac_nc - 1 { (v[i][j] + v[i][j + 1]) / 2.0 } else { 0.0 }
      let v_w    = if j > 0 { (v[i][j - 1] + v[i][j]) / 2.0 } else { 0.0 }
      let conv_x = dt_ / dx_ * (u_e * v_e - u_w * v_w)

      // Viscosity in y
      let visc_y  = nu_ * dt_ / dy2 * (v[i + 1][j] - 2.0 * v[i][j] + v[i - 1][j])

      // Viscosity in x with ghost cells for left/right walls
      let v_right = if j < mac_nc - 1 { v[i][j + 1] } else { -v[i][j] }
      let v_left  = if j > 0 { v[i][j - 1] } else { -v[i][j] }
      let visc_x  = nu_ * dt_ / dx2 * (v_right - 2.0 * v[i][j] + v_left)

      vs[i][j] = v[i][j] - conv_y - conv_x + visc_y + visc_x
    }
  }
  for j = 0; j < mac_nc; j = j + 1 {
    vs[0][j]      = 0.0
    vs[mac_nc][j] = 0.0
  }
}

// ── Staggered divergence → pressure Poisson RHS ──────────────────────────────
fn build_up_b_mac(
  b    : Array[Array[Double]],
  rho_ : Double,
  dt_  : Double,
  us   : Array[Array[Double]],
  vs   : Array[Array[Double]],
  dx_  : Double,
  dy_  : Double,
) -> Unit {
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 {
      let du  = (us[i][j + 1] - us[i][j]) / dx_
      let dv  = (vs[i + 1][j] - vs[i][j]) / dy_
      b[i][j] = rho_ / dt_ * (du + dv)
    }
  }
}

// ── MAC velocity correction ───────────────────────────────────────────────────
fn mac_correct_velocity(
  us   : Array[Array[Double]],
  vs   : Array[Array[Double]],
  p    : Array[Array[Double]],
  dt_  : Double,
  dx_  : Double,
  dy_  : Double,
  rho_ : Double,
  u    : Array[Array[Double]],
  v    : Array[Array[Double]],
) -> Unit {
  let cu = dt_ / rho_ / dx_
  let cv = dt_ / rho_ / dy_
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 1; j < mac_nc; j = j + 1 {
      u[i][j] = us[i][j] - cu * (p[i][j] - p[i][j - 1])
    }
    u[i][0]      = 0.0
    u[i][mac_nc] = 0.0
  }
  for j = 0; j < mac_nc; j = j + 1 {
    for i = 1; i < mac_nc; i = i + 1 {
      v[i][j] = vs[i][j] - cv * (p[i][j] - p[i - 1][j])
    }
    v[0][j]      = 0.0
    v[mac_nc][j] = 0.0
  }
}

// ── MAC Chorin-PCG time-marching solver ───────────────────────────────────────
fn cavity_flow_mac(
  nt_steps  : Int,
  u         : Array[Array[Double]],
  v         : Array[Array[Double]],
  dt_       : Double,
  dx_       : Double,
  dy_       : Double,
  p         : Array[Array[Double]],
  rho_      : Double,
  nu_       : Double,
  pcg_iters : Array[Int],
) -> (Array[Array[Double]], Array[Array[Double]], Array[Array[Double]]) {
  let us = create_zeros_2d(mac_nc, mac_nc + 1)
  let vs = create_zeros_2d(mac_nc + 1, mac_nc)
  let b  = create_zeros_2d(mac_nc, mac_nc)

  for n = 0; n < nt_steps; n = n + 1 {
    mac_u_predictor(u, v, dt_, dx_, dy_, nu_, us)
    mac_v_predictor(u, v, dt_, dx_, dy_, nu_, vs)
    build_up_b_mac(b, rho_, dt_, us, vs, dx_, dy_)
    let iters = pressure_poisson_pcg_mac(p, dx_, dy_, b)
    pcg_iters[0] = iters
    mac_correct_velocity(us, vs, p, dt_, dx_, dy_, rho_, u, v)
    if (n + 1) % 10 == 0 {
      println("MAC step \{n + 1}/\{nt_steps}: pressure iters=\{iters}")
    }
  }
  (u, v, p)
}

// ── Global MAC state ──────────────────────────────────────────────────────────
let g_u_mac : Array[Array[Double]] = {
  let a = Array::make(mac_nc, Array::make(mac_nc + 1, 0.0))
  for i = 0; i < mac_nc; i = i + 1 { a[i] = Array::make(mac_nc + 1, 0.0) }
  a
}

let g_v_mac : Array[Array[Double]] = {
  let a = Array::make(mac_nc + 1, Array::make(mac_nc, 0.0))
  for i = 0; i < mac_nc + 1; i = i + 1 { a[i] = Array::make(mac_nc, 0.0) }
  a
}

let g_p_mac : Array[Array[Double]] = {
  let a = Array::make(mac_nc, Array::make(mac_nc, 0.0))
  for i = 0; i < mac_nc; i = i + 1 { a[i] = Array::make(mac_nc, 0.0) }
  a
}

let g_steps_mac      : Array[Int] = [0]
let g_mac_last_iters : Array[Int] = [0]

// ── WASM API – MAC solver ─────────────────────────────────────────────────────

pub fn init_mac() -> Unit {
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc + 1; j = j + 1 { g_u_mac[i][j] = 0.0 }
  }
  for i = 0; i < mac_nc + 1; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 { g_v_mac[i][j] = 0.0 }
  }
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 { g_p_mac[i][j] = 0.0 }
  }
  g_steps_mac[0]      = 0
  g_mac_last_iters[0] = 0
}

pub fn run_mac_n_steps(n : Int) -> Unit {
  let (u_out, v_out, p_out) = cavity_flow_mac(
    n, g_u_mac, g_v_mac, dt, dx, dy, g_p_mac, rho, nu, g_mac_last_iters,
  )
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc + 1; j = j + 1 { g_u_mac[i][j] = u_out[i][j] }
  }
  for i = 0; i < mac_nc + 1; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 { g_v_mac[i][j] = v_out[i][j] }
  }
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 { g_p_mac[i][j] = p_out[i][j] }
  }
  g_steps_mac[0] = g_steps_mac[0] + n
}

pub fn get_mac_step_count() -> Int { g_steps_mac[0] }
pub fn get_mac_last_iters() -> Int { g_mac_last_iters[0] }

/// Grid dimension for the MAC solver (number of cells per direction).
pub fn get_mac_nc() -> Int { mac_nc }

/// u interpolated to cell centre (i, j), i,j ∈ [0, mac_nc).
pub fn get_u_mac_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < mac_nc && j >= 0 && j < mac_nc {
    (g_u_mac[i][j] + g_u_mac[i][j + 1]) / 2.0
  } else { 0.0 }
}

/// v interpolated to cell centre (i, j).
pub fn get_v_mac_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < mac_nc && j >= 0 && j < mac_nc {
    (g_v_mac[i][j] + g_v_mac[i + 1][j]) / 2.0
  } else { 0.0 }
}

pub fn get_p_mac_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < mac_nc && j >= 0 && j < mac_nc { g_p_mac[i][j] } else { 0.0 }
}

pub fn get_velocity_magnitude_mac_at(i : Int, j : Int) -> Double {
  let u_ = get_u_mac_at(i, j)
  let v_ = get_v_mac_at(i, j)
  (u_ * u_ + v_ * v_).sqrt()
}

pub fn get_max_u_mac() -> Double {
  let mut m = 0.0
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 {
      let val = get_u_mac_at(i, j).abs()
      if val > m { m = val }
    }
  }
  m
}

pub fn get_max_v_mac() -> Double {
  let mut m = 0.0
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 {
      let val = get_v_mac_at(i, j).abs()
      if val > m { m = val }
    }
  }
  m
}

pub fn get_max_p_mac() -> Double {
  let mut m = g_p_mac[0][0]
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 {
      if g_p_mac[i][j] > m { m = g_p_mac[i][j] }
    }
  }
  m
}

pub fn get_min_p_mac() -> Double {
  let mut m = g_p_mac[0][0]
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 {
      if g_p_mac[i][j] < m { m = g_p_mac[i][j] }
    }
  }
  m
}

/// RMS divergence ‖∇·u‖_RMS over the PCG-interior MAC cells (i=1..mac_nc-2, j=1..mac_nc-2).
/// By the staggered projection theorem, every cell whose pressure is solved by the
/// PCG has exactly-zero discrete divergence (up to PCG tolerance).
/// Boundary columns/rows are excluded:
///   top row (i=mac_nc-1): Dirichlet p=0 prevents correction at the lid face
///   left/right cols (j=0, j=mac_nc-1): Neumann ghost makes the x-gradient zero there
///   bottom row (i=0): Neumann ghost makes the y-gradient zero there
pub fn get_mac_divergence_norm() -> Double {
  let mut sum = 0.0
  let cnt = (mac_nc - 2) * (mac_nc - 2)
  for i = 1; i < mac_nc - 1; i = i + 1 {
    for j = 1; j < mac_nc - 1; j = j + 1 {
      let du = (g_u_mac[i][j + 1] - g_u_mac[i][j]) / dx
      let dv = (g_v_mac[i + 1][j] - g_v_mac[i][j]) / dy
      let d  = du + dv
      sum    = sum + d * d
    }
  }
  if cnt > 0 { (sum / cnt.to_double()).sqrt() } else { 0.0 }
}

// ── JSON helpers for MAC grid ─────────────────────────────────────────────────

/// Compute field statistics for the MAC solver (operates on cell-centre values).
fn field_stats_mac() -> (Double, Double, Double, Double, Double, Double, Double, Double, Double) {
  let mut mu = 0.0
  let mut mv = 0.0
  let mut mp = g_p_mac[0][0]
  let mut np_ = g_p_mac[0][0]
  let mut mm = 0.0
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 {
      let u_ = get_u_mac_at(i, j)
      let v_ = get_v_mac_at(i, j)
      let au = u_.abs()
      let av = v_.abs()
      if au > mu { mu = au }
      if av > mv { mv = av }
      if g_p_mac[i][j] > mp { mp = g_p_mac[i][j] }
      if g_p_mac[i][j] < np_ { np_ = g_p_mac[i][j] }
      let mag = (u_ * u_ + v_ * v_).sqrt()
      if mag > mm { mm = mag }
    }
  }
  let dn  = get_mac_divergence_norm()
  let mi  = mac_nc / 2
  let cu  = get_u_mac_at(mi, mi)
  let cv_ = get_v_mac_at(mi, mi)
  let cp  = g_p_mac[mi][mi]
  (mu, mv, mp, np_, mm, dn, cu, cv_, cp)
}

/// Emit MAC grid as a JSON array keyed by json_key.
/// Cell centres at x=(j+0.5)*dx, y=(i+0.5)*dy.
fn emit_grid_mac(json_key : String, trailing_comma : Bool) -> Unit {
  println("  \"\{json_key}\": [")
  for i = 0; i < mac_nc; i = i + 1 {
    for j = 0; j < mac_nc; j = j + 1 {
      let x_pos = (j.to_double() + 0.5) * dx
      let y_pos = (i.to_double() + 0.5) * dy
      let u_    = get_u_mac_at(i, j)
      let v_    = get_v_mac_at(i, j)
      let p_    = g_p_mac[i][j]
      let mag   = (u_ * u_ + v_ * v_).sqrt()
      let comma = if i == mac_nc - 1 && j == mac_nc - 1 { "" } else { "," }
      println("    {\"i\":\{i},\"j\":\{j},\"x\":\{x_pos},\"y\":\{y_pos},\"u\":\{u_},\"v\":\{v_},\"p\":\{p_},\"magnitude\":\{mag}}\{comma}")
    }
  }
  if trailing_comma {
    println("  ],")
  } else {
    println("  ]")
  }
}

// Fibonacci helper – used only by the bench test in main_bench.mbt.
fn fib(n : Int) -> Int {
  if n < 2 { return n }
  return fib(n - 1) + fib(n - 2)
}


// ── Local entry point ─────────────────────────────────────────────────────────
//
// `moon run cmd/main [--target wasm]`
//
// Controls: edit the constants at the top of this file (run_chorin, run_simple,
// local_nt, local_simple_n, timing_enabled, time_chorin_phase, time_simple_phase).
//
// Workflow:
//   1. bash run_local.sh          → runs both solvers, writes results.json
//   2. Open cmd/main/local_viewer.html in a browser, drag results.json in.
//   3. Use the Chorin / SIMPLE tab to switch between solver views.
fn main {
  let prog_ts = @bench.monotonic_clock_start()

  println("=== FlowLabLite – Local CFD Solver ===")
  println("Grid: \{nx}×\{ny}  |  Re = \{1.0 * 2.0 / nu}")
  if run_chorin { println("  Chorin     : \{local_nt} steps   (nt_max = \{nt})") }
  if run_simple { println("  SIMPLE     : \{local_simple_n} iterations") }
  if run_pcg    { println("  Chorin-PCG : \{local_pcg_nt} steps  (tol=\{pcg_tol})") }
  if run_mac    { println("  MAC-PCG    : \{local_mac_nt} steps  (staggered, tol=\{pcg_tol})") }
  println("")

  // ── Chorin (projection method, explicit time-marching) ─────────────────────
  let c_init_ms = if run_chorin {
    timed(timing_enabled && time_chorin_phase, "Chorin init", fn() {
      init_simulation()
    })
  } else { 0.0 }

  let c_run_ms = if run_chorin {
    timed(timing_enabled && time_chorin_phase, "Chorin \{local_nt} steps", fn() {
      run_n_steps(local_nt)
    })
  } else { 0.0 }

  // ── SIMPLE (pressure-correction, steady-state) ─────────────────────────────
  let s_init_ms = if run_simple {
    timed(timing_enabled && time_simple_phase, "SIMPLE init", fn() {
      init_simple()
    })
  } else { 0.0 }

  let s_run_ms = if run_simple {
    timed(timing_enabled && time_simple_phase, "SIMPLE \{local_simple_n} iters", fn() {
      run_simple_n_iter(local_simple_n)
    })
  } else { 0.0 }

  // ── Chorin-PCG (projection method with PCG pressure solver) ────────────────
  let p_init_ms = if run_pcg {
    timed(timing_enabled, "PCG init", fn() { init_chorin_pcg() })
  } else { 0.0 }

  let p_run_ms = if run_pcg {
    timed(timing_enabled, "PCG \{local_pcg_nt} steps", fn() {
      run_chorin_pcg_n_steps(local_pcg_nt)
    })
  } else { 0.0 }

  // ── MAC staggered grid with PCG pressure solver ────────────────────────────
  let m_init_ms = if run_mac {
    timed(timing_enabled, "MAC init", fn() { init_mac() })
  } else { 0.0 }

  let m_run_ms = if run_mac {
    timed(timing_enabled, "MAC \{local_mac_nt} steps", fn() {
      run_mac_n_steps(local_mac_nt)
    })
  } else { 0.0 }

  let total_ms = @bench.monotonic_clock_end(prog_ts) / 1000.0

  // ── Timing summary ─────────────────────────────────────────────────────────
  if timing_enabled {
    println("")
    println("=== Timing Summary ===")
    if run_chorin {
      println("  Chorin init : \{c_init_ms} ms")
      println("  Chorin run  : \{c_run_ms} ms")
    }
    if run_simple {
      println("  SIMPLE init : \{s_init_ms} ms")
      println("  SIMPLE run  : \{s_run_ms} ms")
    }
    if run_pcg {
      println("  PCG init    : \{p_init_ms} ms")
      println("  PCG run     : \{p_run_ms} ms")
    }
    if run_mac {
      println("  MAC init    : \{m_init_ms} ms")
      println("  MAC run     : \{m_run_ms} ms")
    }
    println("  Total       : \{total_ms} ms")
  }

  // ── JSON output ────────────────────────────────────────────────────────────
  println("")
  println("=== Generating JSON for local_viewer.html ===")
  output_json(
    g_u, g_v, g_p, local_nt,
    g_u_s, g_v_s, g_p_s, local_simple_n, g_simple_residual[0],
    g_u_pcg, g_v_pcg, g_p_pcg, local_pcg_nt,
    local_mac_nt,
    c_init_ms, c_run_ms, s_init_ms, s_run_ms, p_init_ms, p_run_ms,
    m_init_ms, m_run_ms,
    total_ms,
  )
  println("=== Done – drag results.json into cmd/main/local_viewer.html ===")
}
