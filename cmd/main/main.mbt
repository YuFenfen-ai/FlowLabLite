// Constants for the simulation
let nx = 41
let ny = 41
let nt = 500
let nit = 50
let _c = 1.0
let dx : Double = 2.0 / (nx - 1).to_double()
let dy : Double = 2.0 / (ny - 1).to_double()
let rho = 1.0
let nu = 0.1
let dt = 0.001
// ── Local run configuration ───────────────────────────────────────────────────
// These constants control `moon run cmd/main` (local workflow) only.
// They have NO effect on the exported WASM API used by the browser viewer.

/// Master on/off switch for timing output.
/// false = suppress all [Timing] lines (solvers still run normally).
let timing_enabled : Bool = true

/// Time the Chorin solver init and run phases individually.
let time_chorin_phase : Bool = true

/// Time the SIMPLE solver init and run phases individually.
let time_simple_phase : Bool = true

/// Include the Chorin (projection-method, explicit time-marching) solver.
let run_chorin : Bool = true

/// Chorin time steps to execute locally.  Maximum = nt = 500.
/// Set to e.g. 100 for a faster preview run.
let local_nt : Int = nt

/// Include the SIMPLE (steady-state, pressure-correction) solver.
let run_simple : Bool = true

/// Number of SIMPLE iterations to execute locally.
let local_simple_n : Int = 100

// ── Timing helper ─────────────────────────────────────────────────────────────
// Backed by @bench.monotonic_clock_start / monotonic_clock_end, which are
// implemented natively for both --target native and --target wasm via the
// Wasmtime host import "__moonbit_time_unstable"."instant_now".

/// Execute f(), measure wall-clock elapsed time, return milliseconds.
/// Prints a labelled line when enabled=true. Returns 0.0 when enabled=false.
fn timed(enabled : Bool, label : String, f : () -> Unit) -> Double {
  if not(enabled) {
    f()
    0.0
  } else {
    let ts = @bench.monotonic_clock_start()
    f()
    let ms = @bench.monotonic_clock_end(ts) / 1000.0
    println("[Timing] \{label}: \{ms} ms")
    ms
  }
}

// ── Global simulation state (written by init_simulation / run_all_steps) ──
// These are allocated once; JS calls init_simulation() before run_all_steps().
let g_u : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

let g_v : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

let g_p : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

// ── Global step counter (single-element array, writable at global scope) ──
let g_steps : Array[Int] = [0]

// ── Primitive accessors exported to WASM ──

/// Return grid width (nx).
pub fn get_nx() -> Int { nx }

/// Return grid height (ny).
pub fn get_ny() -> Int { ny }

/// Return total time-step count (nt).
pub fn get_nt() -> Int { nt }

/// Return Reynolds number Re = u_lid * L / nu  (u_lid=1, L=2).
pub fn get_re() -> Double { 1.0 * 2.0 / nu }

/// Return number of pressure Poisson inner iterations per time step (nit).
pub fn get_nit() -> Int { nit }

/// Return grid spacing in x.
pub fn get_dx() -> Double { dx }

/// Return grid spacing in y.
pub fn get_dy() -> Double { dy }

/// Return time step size dt.
pub fn get_dt() -> Double { dt }

/// Return fluid density rho.
pub fn get_rho() -> Double { rho }

/// Return kinematic viscosity nu.
pub fn get_nu() -> Double { nu }

/// Return how many solver steps have been executed since the last init_simulation().
pub fn get_step_count() -> Int { g_steps[0] }

/// Reset the global u, v, p arrays to zero so a fresh simulation can start.
/// JS must call this before run_all_steps().
pub fn init_simulation() -> Unit {
  g_steps[0] = 0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u[i][j] = 0.0
      g_v[i][j] = 0.0
      g_p[i][j] = 0.0
    }
  }
}

/// Read u-velocity at grid index (i=row, j=col).  Returns 0 for out-of-range.
pub fn get_u_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_u[i][j] } else { 0.0 }
}

/// Read v-velocity at grid index (i=row, j=col).  Returns 0 for out-of-range.
pub fn get_v_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_v[i][j] } else { 0.0 }
}

/// Read pressure at grid index (i=row, j=col).  Returns 0 for out-of-range.
pub fn get_p_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_p[i][j] } else { 0.0 }
}

/// Return velocity magnitude sqrt(u²+v²) at grid index (i,j).
pub fn get_velocity_magnitude_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx {
    let u = g_u[i][j]
    let v = g_v[i][j]
    (u * u + v * v).sqrt()
  } else {
    0.0
  }
}

/// Return maximum absolute u-velocity over the whole grid.
pub fn get_max_u() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let v = g_u[i][j].abs()
      if v > m { m = v }
    }
  }
  m
}

/// Return maximum absolute v-velocity over the whole grid.
pub fn get_max_v() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let v = g_v[i][j].abs()
      if v > m { m = v }
    }
  }
  m
}

/// Return maximum pressure value over the whole grid.
pub fn get_max_p() -> Double {
  let mut m = g_p[0][0]
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      if g_p[i][j] > m { m = g_p[i][j] }
    }
  }
  m
}

/// Return minimum pressure value over the whole grid.
pub fn get_min_p() -> Double {
  let mut m = g_p[0][0]
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      if g_p[i][j] < m { m = g_p[i][j] }
    }
  }
  m
}

/// Return u at the grid centre (ny/2, nx/2) – convenient for convergence monitoring.
pub fn get_u_center() -> Double { g_u[ny / 2][nx / 2] }

/// Return v at the grid centre.
pub fn get_v_center() -> Double { g_v[ny / 2][nx / 2] }

/// Return pressure at the grid centre.
pub fn get_p_center() -> Double { g_p[ny / 2][nx / 2] }

/// Return mean absolute divergence ∑|∂u/∂x + ∂v/∂y| / (interior cells) as a
/// rough indicator of how well mass conservation is satisfied after the last step.
pub fn get_divergence_norm() -> Double {
  let mut sum = 0.0
  let count = (ny - 2) * (nx - 2)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let div = (g_u[i][j + 1] - g_u[i][j - 1]) / (2.0 * dx) +
                (g_v[i + 1][j] - g_v[i - 1][j]) / (2.0 * dy)
      sum = sum + div.abs()
    }
  }
  if count > 0 { sum / count.to_double() } else { 0.0 }
}

/// Return the maximum velocity magnitude sqrt(u²+v²) over the whole grid.
pub fn get_max_velocity_magnitude() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let u = g_u[i][j]
      let v = g_v[i][j]
      let mag = (u * u + v * v).sqrt()
      if mag > m { m = mag }
    }
  }
  m
}

/// Run exactly n time steps starting from the current global state.
/// JS can call this in chunks to implement progressive visualization.
/// init_simulation() must be called once before the first chunk.
pub fn run_n_steps(n : Int) -> Unit {
  let (u_out, v_out, p_out) = cavity_flow_array(
    n, g_u, g_v, dt, dx, dy, g_p, rho, nu,
  )
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u[i][j] = u_out[i][j]
      g_v[i][j] = v_out[i][j]
      g_p[i][j] = p_out[i][j]
    }
  }
  g_steps[0] = g_steps[0] + n
}

/// Run the full cavity-flow solver (nt steps) and store results in g_u/g_v/g_p.
/// JS workflow:  init_simulation() → run_all_steps() → get_u_at/get_v_at/get_p_at
pub fn run_all_steps() -> Unit {
  let (u_out, v_out, p_out) = cavity_flow_array(
    nt, g_u, g_v, dt, dx, dy, g_p, rho, nu,
  )
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u[i][j] = u_out[i][j]
      g_v[i][j] = v_out[i][j]
      g_p[i][j] = p_out[i][j]
    }
  }
  g_steps[0] = nt
}

// Helper function to create 2D array filled with zeros
fn create_zeros_2d(rows : Int, cols : Int) -> Array[Array[Double]] {
  let result = Array::make(rows, Array::make(cols, 0.0))
  for i = 0; i < rows; i = i + 1 {
    result[i] = Array::make(cols, 0.0)
  }
  result
}
// Helper function to copy 2D array
fn copy_2d_array(src : Array[Array[Double]], dst : Array[Array[Double]]) -> Unit {
  for i = 0; i < src.length(); i = i + 1 {
    for j = 0; j < src[i].length(); j = j + 1 {
      dst[i][j] = src[i][j]
    }
  }
}
// Generate mesh coordinates (equivalent to numpy.linspace and meshgrid)
fn generate_mesh_grid() -> (Array[Array[Double]], Array[Array[Double]]) {
  let x_coords = Array::make(nx, 0.0)
  let y_coords = Array::make(ny, 0.0)
  
  // Generate x coordinates (0 to 2)
  for i = 0; i < nx; i = i + 1 {
    x_coords[i] = 2.0 * i.to_double() / (nx - 1).to_double()
  }
  
  // Generate y coordinates (0 to 2)
  for j = 0; j < ny; j = j + 1 {
    y_coords[j] = 2.0 * j.to_double() / (ny - 1).to_double()
  }
  
  // Create meshgrid - 修正：为每行创建新的数组
  let x = Array::make(ny, Array::make(nx, 0.0))
  let y = Array::make(ny, Array::make(nx, 0.0))
  
  for i = 0; i < ny; i = i + 1 {
    x[i] = Array::make(nx, 0.0)  // 为每行创建新数组
    y[i] = Array::make(nx, 0.0)  // 为每行创建新数组
    for j = 0; j < nx; j = j + 1 {
      x[i][j] = x_coords[j]
      y[i][j] = y_coords[i]
    }
  }
  
  (x, y)
}
// [Layer 2 input] Build the right-hand-side source term b for the pressure
// Poisson linear system  Ax = b,  where x = p (Chorin) or x = p' (SIMPLE).
// b encodes the velocity divergence: b = ρ/dt · ∇·u  (plus higher-order terms).
fn build_up_b_array(b : Array[Array[Double]], rho : Double, dt : Double,
                   u : Array[Array[Double]], v : Array[Array[Double]],
                   dx : Double, dy : Double) -> Array[Array[Double]] {
  
  // Equivalent to b[1:-1, 1:-1] = ... in Python
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      // Calculate velocity divergence terms
      let du_dx = (u[i][j + 1] - u[i][j - 1]) / (2.0 * dx)
      let dv_dy = (v[i + 1][j] - v[i - 1][j]) / (2.0 * dy)
      
      // Calculate squared terms
      let du_dx_squared = du_dx * du_dx
      let dv_dy_squared = dv_dy * dv_dy
      
      // Mixed derivative terms
      let du_dy = (u[i + 1][j] - u[i - 1][j]) / (2.0 * dy)
      let dv_dx = (v[i][j + 1] - v[i][j - 1]) / (2.0 * dx)
      let mixed_term = 2.0 * du_dy * dv_dx
      
      // Assemble the source term
      b[i][j] = rho * (
        (1.0 / dt) * (du_dx + dv_dy) - 
        du_dx_squared - 
        mixed_term - 
        dv_dy_squared
      )
    }
  }
  
  b
}
// [Layer 2: Linear equation solver] Gauss-Seidel iterative solver for the
// pressure Poisson equation  ∇²p = b  (or ∇²p' = b for SIMPLE).
// Performs `nit` sweeps over interior nodes; boundary conditions are re-applied
// each sweep.  Both Chorin and SIMPLE share this single implementation.
fn pressure_poisson_array(p : Array[Array[Double]], dx : Double, dy : Double,
                         b : Array[Array[Double]]) -> Array[Array[Double]] {
  let pn = create_zeros_2d(ny, nx)
  let dx2 = dx * dx
  let dy2 = dy * dy
  let coeff = dx2 * dy2 / (2.0 * (dx2 + dy2))
  let inv_denom = 1.0 / (2.0 * (dx2 + dy2))
  
  for q = 0; q < nit; q = q + 1 {
    copy_2d_array(p, pn)
    
    // Update interior points: p[1:-1, 1:-1] = ...
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let laplacian = (pn[i][j + 1] + pn[i][j - 1]) * dy2 + 
                       (pn[i + 1][j] + pn[i - 1][j]) * dx2
        
        p[i][j] = laplacian * inv_denom - coeff * b[i][j]
      }
    }
    
    // Apply boundary conditions
    // p[:, -1] = p[:, -2]  (dp/dx = 0 at x = 2)
    for i = 0; i < ny; i = i + 1 {
      p[i][nx - 1] = p[i][nx - 2]
    }
    
    // p[0, :] = p[1, :]  (dp/dy = 0 at y = 0)
    for j = 0; j < nx; j = j + 1 {
      p[0][j] = p[1][j]
    }
    
    // p[:, 0] = p[:, 1]  (dp/dx = 0 at x = 0)
    for i = 0; i < ny; i = i + 1 {
      p[i][0] = p[i][1]
    }
    
    // p[-1, :] = 0  (p = 0 at y = 2)
    for j = 0; j < nx; j = j + 1 {
      p[ny - 1][j] = 0.0
    }
  }
  
  p
}
// [Layer 1: Pressure-velocity coupling algorithm] Chorin projection method
// (Chorin 1968, operator splitting / fractional-step method):
//   Each time step:
//     1. Explicit scheme velocity prediction (no linear system – direct substitution)
//     2. Build Poisson source term  b = ρ/dt · ∇·ũ
//     3. Gauss-Seidel solve  ∇²p = b  (Layer 2, `nit` inner iterations)
//     4. Project  u ← ũ − (dt/ρ) ∇p  (explicit update, enforces ∇·u = 0)
//   Repeats for `nt` time steps (transient simulation).
///|
fn cavity_flow_array(
  nt : Int,
  u : Array[Array[Double]],
  v : Array[Array[Double]],
  dt : Double,
  dx : Double,
  dy : Double,
  p : Array[Array[Double]],
  rho : Double,
  nu : Double,
) -> (Array[Array[Double]], Array[Array[Double]], Array[Array[Double]]) {
  let un = create_zeros_2d(ny, nx)
  let vn = create_zeros_2d(ny, nx)
  let b = create_zeros_2d(ny, nx)

  for n = 0; n < nt; n = n + 1 {
    copy_2d_array(u, un)
    copy_2d_array(v, vn)

    // Build divergence source term b  [Layer 2 input]
    build_up_b_array(b, rho, dt, u, v, dx, dy) |> ignore

    // Gauss-Seidel solve  ∇²p = b  [Layer 2 linear equation solver]
    pressure_poisson_array(p, dx, dy, b) |> ignore

    // Explicit scheme velocity update (projection step, no linear system)
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let conv_u_x = un[i][j] * dt / dx * (un[i][j] - un[i][j - 1])
        let conv_u_y = vn[i][j] * dt / dy * (un[i][j] - un[i - 1][j])
        let pressure_grad = dt / (2.0 * rho * dx) * (p[i][j + 1] - p[i][j - 1])
        let visc_u_x = nu *
          dt /
          (dx * dx) *
          (un[i][j + 1] - 2.0 * un[i][j] + un[i][j - 1])
        let visc_u_y = nu *
          dt /
          (dy * dy) *
          (un[i + 1][j] - 2.0 * un[i][j] + un[i - 1][j])

        u[i][j] = un[i][j] -
          conv_u_x -
          conv_u_y -
          pressure_grad +
          visc_u_x +
          visc_u_y
      }
    }

    // Update v velocity component
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let conv_v_x = un[i][j] * dt / dx * (vn[i][j] - vn[i][j - 1])
        let conv_v_y = vn[i][j] * dt / dy * (vn[i][j] - vn[i - 1][j])
        let pressure_grad = dt / (2.0 * rho * dy) * (p[i + 1][j] - p[i - 1][j])
        let visc_v_x = nu *
          dt /
          (dx * dx) *
          (vn[i][j + 1] - 2.0 * vn[i][j] + vn[i][j - 1])
        let visc_v_y = nu *
          dt /
          (dy * dy) *
          (vn[i + 1][j] - 2.0 * vn[i][j] + vn[i - 1][j])

        v[i][j] = vn[i][j] -
          conv_v_x -
          conv_v_y -
          pressure_grad +
          visc_v_x +
          visc_v_y
      }
    }

    // Apply velocity boundary conditions
    // u[0, :] = 0, u[:, 0] = 0, u[:, -1] = 0
    for j = 0; j < nx; j = j + 1 {
      u[0][j] = 0.0
    }
    for i = 0; i < ny; i = i + 1 {
      u[i][0] = 0.0
      u[i][nx - 1] = 0.0
    }
    // u[-1, :] = 1 (cavity lid velocity)
    for j = 0; j < nx; j = j + 1 {
      u[ny - 1][j] = 1.0
    }

    // v[0, :] = 0, v[-1, :] = 0, v[:, 0] = 0, v[:, -1] = 0
    for j = 0; j < nx; j = j + 1 {
      v[0][j] = 0.0
      v[ny - 1][j] = 0.0
    }
    for i = 0; i < ny; i = i + 1 {
      v[i][0] = 0.0
      v[i][nx - 1] = 0.0
    }

    // Progress output every 10 steps
    if (n + 1) % 10 == 0 {
      println("Time step \{n + 1}/\{nt} completed")
    }
  }

  (u, v, p)
}

// ── JSON output for local run results ────────────────────────────────────────
//
// Outputs a single JSON document that contains results for BOTH solvers (Chorin
// and SIMPLE).  The "statistics"/"grid" keys hold Chorin data for backward
// compatibility with existing local_viewer.html files; the "simple_statistics"/
// "simple_grid" keys hold SIMPLE data.  "config.solver" records which solvers
// actually ran ("chorin" | "simple" | "both").

/// Compute field statistics over a u/v/p grid.
/// Returns (max_|u|, max_|v|, max_p, min_p, max_|V|, div_norm, center_u, center_v, center_p).
fn field_stats(
  u : Array[Array[Double]],
  v : Array[Array[Double]],
  p : Array[Array[Double]],
) -> (Double, Double, Double, Double, Double, Double, Double, Double, Double) {
  let mut mu = 0.0; let mut mv = 0.0
  let mut mp = p[0][0]; let mut np_ = p[0][0]; let mut mm = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let au = u[i][j].abs(); let av = v[i][j].abs()
      if au > mu { mu = au }
      if av > mv { mv = av }
      if p[i][j] > mp { mp = p[i][j] }
      if p[i][j] < np_ { np_ = p[i][j] }
      let mag = (u[i][j] * u[i][j] + v[i][j] * v[i][j]).sqrt()
      if mag > mm { mm = mag }
    }
  }
  let mut ds = 0.0
  let dc = (ny - 2) * (nx - 2)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let d = (u[i][j + 1] - u[i][j - 1]) / (2.0 * dx) +
              (v[i + 1][j] - v[i - 1][j]) / (2.0 * dy)
      ds = ds + d.abs()
    }
  }
  let dn = if dc > 0 { ds / dc.to_double() } else { 0.0 }
  let mi = ny / 2; let mj = nx / 2
  (mu, mv, mp, np_, mm, dn, u[mi][mj], v[mi][mj], p[mi][mj])
}

/// Emit the JSON "statistics" object for a solver's field.
fn emit_stats(
  mu : Double, mv : Double, mp : Double, np_ : Double,
  mm : Double, dn : Double, cu : Double, cv : Double, cp : Double,
  elapsed_ms : Double,
) -> Unit {
  println("    \"max_u\": \{mu}, \"max_v\": \{mv},")
  println("    \"max_p\": \{mp}, \"min_p\": \{np_},")
  println("    \"max_velocity_magnitude\": \{mm},")
  println("    \"divergence_norm\": \{dn},")
  println("    \"center_u\": \{cu}, \"center_v\": \{cv},")
  println("    \"center_p\": \{cp},")
  println("    \"elapsed_seconds\": \{elapsed_ms / 1000.0}")
}

/// Emit a named JSON grid array for a u/v/p field.
/// json_key  – the JSON property name (e.g. "grid" or "simple_grid")
/// trailing_comma – append a "," after the closing "]" when true
fn emit_grid(
  json_key : String,
  u : Array[Array[Double]],
  v : Array[Array[Double]],
  p : Array[Array[Double]],
  trailing_comma : Bool,
) -> Unit {
  println("  \"\{json_key}\": [")
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let x_pos = 2.0 * j.to_double() / (nx - 1).to_double()
      let y_pos = 2.0 * i.to_double() / (ny - 1).to_double()
      let mag = (u[i][j] * u[i][j] + v[i][j] * v[i][j]).sqrt()
      let comma = if i == ny - 1 && j == nx - 1 { "" } else { "," }
      println("    {\"i\":\{i},\"j\":\{j},\"x\":\{x_pos},\"y\":\{y_pos},\"u\":\{u[i][j]},\"v\":\{v[i][j]},\"p\":\{p[i][j]},\"magnitude\":\{mag}}\{comma}")
    }
  }
  if trailing_comma {
    println("  ],")
  } else {
    println("  ]")
  }
}

/// Output full dual-solver JSON to stdout (delimited by JSON_DATA markers).
///
/// Parameters:
///   u_c/v_c/p_c  – Chorin final fields (g_u / g_v / g_p)
///   nt_c         – Chorin steps executed
///   u_s/v_s/p_s  – SIMPLE final fields (g_u_s / g_v_s / g_p_s)
///   n_s          – SIMPLE iterations executed
///   res_s        – SIMPLE last continuity residual
///   ci/cr/si/sr  – per-phase timing in ms (0.0 when timing disabled)
///   total_ms     – total program elapsed ms
fn output_json(
  u_c : Array[Array[Double]], v_c : Array[Array[Double]], p_c : Array[Array[Double]],
  nt_c : Int,
  u_s : Array[Array[Double]], v_s : Array[Array[Double]], p_s : Array[Array[Double]],
  n_s : Int, res_s : Double,
  ci_ms : Double, cr_ms : Double,
  si_ms : Double, sr_ms : Double,
  total_ms : Double,
) -> Unit {
  let solver_str = if run_chorin && run_simple { "both" }
                   else if run_chorin { "chorin" }
                   else { "simple" }

  let (cmu, cmv, cmp, cnp, cmm, cdn, ccu, ccv, ccp) = field_stats(u_c, v_c, p_c)
  let (smu, smv, smp, snp, smm, sdn, scu, scv, scp) = field_stats(u_s, v_s, p_s)

  println("===JSON_DATA_START===")
  println("{")
  println("  \"config\": {")
  println("    \"nx\": \{nx}, \"ny\": \{ny}, \"nt\": \{nt_c},")
  println("    \"nit\": \{nit}, \"dt\": \{dt}, \"dx\": \{dx}, \"dy\": \{dy},")
  println("    \"rho\": \{rho}, \"nu\": \{nu}, \"re\": \{1.0 * 2.0 / nu},")
  println("    \"solver\": \"\{solver_str}\",")
  println("    \"simple_iters\": \{n_s}")
  println("  },")
  println("  \"timing\": {")
  println("    \"enabled\": \{timing_enabled},")
  println("    \"chorin_init_ms\": \{ci_ms}, \"chorin_run_ms\": \{cr_ms},")
  println("    \"simple_init_ms\": \{si_ms}, \"simple_run_ms\": \{sr_ms},")
  println("    \"total_ms\": \{total_ms}")
  println("  },")
  // ── Chorin section (backward-compatible keys "statistics" + "grid") ──
  println("  \"statistics\": {")
  emit_stats(cmu, cmv, cmp, cnp, cmm, cdn, ccu, ccv, ccp, ci_ms + cr_ms)
  println("  },")
  emit_grid("grid", u_c, v_c, p_c, true)
  // ── SIMPLE section ──
  println("  \"simple_statistics\": {")
  println("    \"residual\": \{res_s},")
  emit_stats(smu, smv, smp, snp, smm, sdn, scu, scv, scp, si_ms + sr_ms)
  println("  },")
  emit_grid("simple_grid", u_s, v_s, p_s, false)
  println("}")
  println("===JSON_DATA_END===")
}

// ── [Layer 1: Pressure-velocity coupling algorithm] SIMPLE ──────────────────
// Semi-Implicit Method for Pressure-Linked Equations
// (Patankar & Spalding 1972, steady-state predictor-corrector iteration):
//
// Each SIMPLE sweep:
//   1. Momentum predictor (explicit scheme): u*, v* from current p*  – no linear system
//   2. Build pressure-correction source  b = −∇·u*  (Layer 2 input)
//   3. Gauss-Seidel solve  ∇²p' = b  (Layer 2, `nit` inner iterations)
//   4. Update:  p = p* + α_p · p'
//               u = u* − (dt/ρ) · ∂p'/∂x,  v = v* − (dt/ρ) · ∂p'/∂y
//   5. Apply boundary conditions; compute convergence residual ‖div u‖
//   Repeat until residual < tolerance.
//
// Under-relaxation factors:
let simple_alpha_p : Double = 0.3   // pressure under-relaxation (stabilises convergence)
let simple_alpha_u : Double = 0.7   // velocity under-relaxation

// Global SIMPLE state arrays (same 41×41 grid as the original solver)
let g_u_s : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

let g_v_s : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

let g_p_s : Array[Array[Double]] = {
  let a = Array::make(ny, Array::make(nx, 0.0))
  for i = 0; i < ny; i = i + 1 {
    a[i] = Array::make(nx, 0.0)
  }
  a
}

// Iteration counter and convergence residual for SIMPLE
let g_simple_iters    : Array[Int]    = [0]
let g_simple_residual : Array[Double] = [0.0]

/// Reset the SIMPLE global state to zero so a fresh solve can start.
pub fn init_simple() -> Unit {
  g_simple_iters[0]    = 0
  g_simple_residual[0] = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      g_u_s[i][j] = 0.0
      g_v_s[i][j] = 0.0
      g_p_s[i][j] = 0.0
    }
  }
}

/// Return the number of SIMPLE iterations completed since init_simple().
pub fn get_simple_step_count() -> Int { g_simple_iters[0] }

/// Return the latest continuity residual ‖div u‖ from SIMPLE.
pub fn get_simple_residual() -> Double { g_simple_residual[0] }

/// Read SIMPLE u-velocity at grid index (i, j).  Returns 0 for out-of-range.
pub fn get_u_simple_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_u_s[i][j] } else { 0.0 }
}

/// Read SIMPLE v-velocity at grid index (i, j).  Returns 0 for out-of-range.
pub fn get_v_simple_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_v_s[i][j] } else { 0.0 }
}

/// Read SIMPLE pressure at grid index (i, j).  Returns 0 for out-of-range.
pub fn get_p_simple_at(i : Int, j : Int) -> Double {
  if i >= 0 && i < ny && j >= 0 && j < nx { g_p_s[i][j] } else { 0.0 }
}

/// Return maximum absolute u from the SIMPLE field.
pub fn get_max_u_simple() -> Double {
  let mut m = 0.0
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let v = g_u_s[i][j].abs()
      if v > m { m = v }
    }
  }
  m
}

/// Return mean |∂u/∂x + ∂v/∂y| for the SIMPLE velocity field.
pub fn get_simple_divergence_norm() -> Double {
  let mut sum = 0.0
  let count = (ny - 2) * (nx - 2)
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let div = (g_u_s[i][j + 1] - g_u_s[i][j - 1]) / (2.0 * dx) +
                (g_v_s[i + 1][j] - g_v_s[i - 1][j]) / (2.0 * dy)
      sum = sum + div.abs()
    }
  }
  if count > 0 { sum / count.to_double() } else { 0.0 }
}

// One SIMPLE sweep (Layer 1 inner step):
//   (a) Momentum predictor (explicit scheme) → u*, v*  [no linear system]
//   (b) Build divergence source b  [Layer 2 input]
//   (c) Gauss-Seidel solve  ∇²p' = b  [Layer 2 linear equation solver]
//   (d) Field update with under-relaxation
//   (e) Boundary conditions
fn simple_one_iter(
  u  : Array[Array[Double]],
  v  : Array[Array[Double]],
  p  : Array[Array[Double]],
) -> Unit {
  // Working arrays (allocated per-call; 41×41 is small so overhead is acceptable)
  let u_star = create_zeros_2d(ny, nx)
  let v_star = create_zeros_2d(ny, nx)
  let b      = create_zeros_2d(ny, nx)
  let p_corr = create_zeros_2d(ny, nx)

  // ── (a) Momentum predictor (explicit Euler with under-relaxation) ──
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      let conv_u_x = u[i][j] * dt / dx * (u[i][j] - u[i][j - 1])
      let conv_u_y = v[i][j] * dt / dy * (u[i][j] - u[i - 1][j])
      let pg_u     = dt / (2.0 * rho * dx) * (p[i][j + 1] - p[i][j - 1])
      let visc_u_x = nu * dt / (dx * dx) * (u[i][j + 1] - 2.0 * u[i][j] + u[i][j - 1])
      let visc_u_y = nu * dt / (dy * dy) * (u[i + 1][j] - 2.0 * u[i][j] + u[i - 1][j])
      let visc_u   = visc_u_x + visc_u_y
      let u_new    = u[i][j] - conv_u_x - conv_u_y - pg_u + visc_u
      u_star[i][j] = simple_alpha_u * u_new + (1.0 - simple_alpha_u) * u[i][j]

      let conv_v_x = u[i][j] * dt / dx * (v[i][j] - v[i][j - 1])
      let conv_v_y = v[i][j] * dt / dy * (v[i][j] - v[i - 1][j])
      let pg_v     = dt / (2.0 * rho * dy) * (p[i + 1][j] - p[i - 1][j])
      let visc_v_x = nu * dt / (dx * dx) * (v[i][j + 1] - 2.0 * v[i][j] + v[i][j - 1])
      let visc_v_y = nu * dt / (dy * dy) * (v[i + 1][j] - 2.0 * v[i][j] + v[i - 1][j])
      let visc_v   = visc_v_x + visc_v_y
      let v_new    = v[i][j] - conv_v_x - conv_v_y - pg_v + visc_v
      v_star[i][j] = simple_alpha_u * v_new + (1.0 - simple_alpha_u) * v[i][j]
    }
  }

  // BCs for u*, v* – walls first, lid last
  for j = 0; j < nx; j = j + 1 {
    u_star[0][j] = 0.0
    v_star[0][j] = 0.0
    v_star[ny - 1][j] = 0.0
  }
  for i = 0; i < ny; i = i + 1 {
    u_star[i][0]      = 0.0
    u_star[i][nx - 1] = 0.0
    v_star[i][0]      = 0.0
    v_star[i][nx - 1] = 0.0
  }
  for j = 0; j < nx; j = j + 1 {
    u_star[ny - 1][j] = 1.0
  }

  // ── (b) Build pressure-correction source b = −(∂u*/∂x + ∂v*/∂y) ──
  build_up_b_array(b, rho, dt, u_star, v_star, dx, dy) |> ignore

  // ── (c) Gauss-Seidel solve  ∇²p' = b  (Layer 2 linear equation solver) ──
  pressure_poisson_array(p_corr, dx, dy, b) |> ignore

  // ── (d) Update fields with under-relaxation ──
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      p[i][j] = p[i][j] + simple_alpha_p * p_corr[i][j]
      u[i][j] = u_star[i][j] - dt / (2.0 * rho * dx) * (p_corr[i][j + 1] - p_corr[i][j - 1])
      v[i][j] = v_star[i][j] - dt / (2.0 * rho * dy) * (p_corr[i + 1][j] - p_corr[i - 1][j])
    }
  }

  // Pressure BCs (same as existing solver)
  for i = 0; i < ny; i = i + 1 {
    p[i][0]      = p[i][1]
    p[i][nx - 1] = p[i][nx - 2]
  }
  for j = 0; j < nx; j = j + 1 {
    p[0][j]      = p[1][j]
    p[ny - 1][j] = 0.0
  }

  // Velocity BCs – apply walls first, lid last so corners take lid value
  for j = 0; j < nx; j = j + 1 {
    u[0][j] = 0.0
    v[0][j] = 0.0
    v[ny - 1][j] = 0.0
  }
  for i = 0; i < ny; i = i + 1 {
    u[i][0]      = 0.0
    u[i][nx - 1] = 0.0
    v[i][0]      = 0.0
    v[i][nx - 1] = 0.0
  }
  // Lid BC applied last so it overrides corner values
  for j = 0; j < nx; j = j + 1 {
    u[ny - 1][j] = 1.0
  }
}

/// Advance the SIMPLE solver by n iterations.
/// Call init_simple() once before the first invocation.
pub fn run_simple_n_iter(n : Int) -> Unit {
  for _k = 0; _k < n; _k = _k + 1 {
    simple_one_iter(g_u_s, g_v_s, g_p_s)
  }
  g_simple_iters[0] = g_simple_iters[0] + n
  // Compute and cache the continuity residual after this batch
  g_simple_residual[0] = get_simple_divergence_norm()
}

// Fibonacci helper – used only by the bench test in main_bench.mbt.
fn fib(n : Int) -> Int {
  if n < 2 { return n }
  return fib(n - 1) + fib(n - 2)
}


// ── Local entry point ─────────────────────────────────────────────────────────
//
// `moon run cmd/main [--target wasm]`
//
// Controls: edit the constants at the top of this file (run_chorin, run_simple,
// local_nt, local_simple_n, timing_enabled, time_chorin_phase, time_simple_phase).
//
// Workflow:
//   1. bash run_local.sh          → runs both solvers, writes results.json
//   2. Open cmd/main/local_viewer.html in a browser, drag results.json in.
//   3. Use the Chorin / SIMPLE tab to switch between solver views.
fn main {
  let prog_ts = @bench.monotonic_clock_start()

  println("=== FlowLabLite – Local CFD Solver ===")
  println("Grid: \{nx}×\{ny}  |  Re = \{1.0 * 2.0 / nu}")
  if run_chorin { println("  Chorin : \{local_nt} steps   (nt_max = \{nt})") }
  if run_simple { println("  SIMPLE : \{local_simple_n} iterations") }
  println("")

  // ── Chorin (projection method, explicit time-marching) ─────────────────────
  let c_init_ms = if run_chorin {
    timed(timing_enabled && time_chorin_phase, "Chorin init", fn() {
      init_simulation()
    })
  } else { 0.0 }

  let c_run_ms = if run_chorin {
    timed(timing_enabled && time_chorin_phase, "Chorin \{local_nt} steps", fn() {
      run_n_steps(local_nt)
    })
  } else { 0.0 }

  // ── SIMPLE (pressure-correction, steady-state) ─────────────────────────────
  let s_init_ms = if run_simple {
    timed(timing_enabled && time_simple_phase, "SIMPLE init", fn() {
      init_simple()
    })
  } else { 0.0 }

  let s_run_ms = if run_simple {
    timed(timing_enabled && time_simple_phase, "SIMPLE \{local_simple_n} iters", fn() {
      run_simple_n_iter(local_simple_n)
    })
  } else { 0.0 }

  let total_ms = @bench.monotonic_clock_end(prog_ts) / 1000.0

  // ── Timing summary ─────────────────────────────────────────────────────────
  if timing_enabled {
    println("")
    println("=== Timing Summary ===")
    if run_chorin {
      println("  Chorin init : \{c_init_ms} ms")
      println("  Chorin run  : \{c_run_ms} ms")
    }
    if run_simple {
      println("  SIMPLE init : \{s_init_ms} ms")
      println("  SIMPLE run  : \{s_run_ms} ms")
    }
    println("  Total       : \{total_ms} ms")
  }

  // ── JSON output ────────────────────────────────────────────────────────────
  println("")
  println("=== Generating JSON for local_viewer.html ===")
  output_json(
    g_u, g_v, g_p, local_nt,
    g_u_s, g_v_s, g_p_s, local_simple_n, g_simple_residual[0],
    c_init_ms, c_run_ms, s_init_ms, s_run_ms, total_ms,
  )
  println("=== Done – drag results.json into cmd/main/local_viewer.html ===")
}
