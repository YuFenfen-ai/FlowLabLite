// Constants for the simulation
let nx = 41
let ny = 41
let nt = 500
let nit = 50
let _c = 1.0
let dx : Double = 2.0 / (nx - 1).to_double()
let dy : Double = 2.0 / (ny - 1).to_double()
let rho = 1.0
let nu = 0.1
let dt = 0.001
// `now_seconds` is normally provided by the host (native object or DLL).
// If you build and provide `now_clock` (DLL / native object), it will override
// this. For now provide a safe fallback implementation so `moon build` succeeds
// in environments without the host symbol. The fallback returns 0.0 meaning
// "timing unavailable".
pub fn now_seconds() -> Double {
  0.0
}
// Helper function to create 2D array filled with zeros
fn create_zeros_2d(rows : Int, cols : Int) -> Array[Array[Double]] {
  let result = Array::make(rows, Array::make(cols, 0.0))
  for i = 0; i < rows; i = i + 1 {
    result[i] = Array::make(cols, 0.0)
  }
  result
}
// Helper function to copy 2D array
fn copy_2d_array(src : Array[Array[Double]], dst : Array[Array[Double]]) -> Unit {
  for i = 0; i < src.length(); i = i + 1 {
    for j = 0; j < src[i].length(); j = j + 1 {
      dst[i][j] = src[i][j]
    }
  }
}
// Generate mesh coordinates (equivalent to numpy.linspace and meshgrid)
fn generate_mesh_grid() -> (Array[Array[Double]], Array[Array[Double]]) {
  let x_coords = Array::make(nx, 0.0)
  let y_coords = Array::make(ny, 0.0)
  
  // Generate x coordinates (0 to 2)
  for i = 0; i < nx; i = i + 1 {
    x_coords[i] = 2.0 * i.to_double() / (nx - 1).to_double()
  }
  
  // Generate y coordinates (0 to 2)
  for j = 0; j < ny; j = j + 1 {
    y_coords[j] = 2.0 * j.to_double() / (ny - 1).to_double()
  }
  
  // Create meshgrid - 修正：为每行创建新的数组
  let x = Array::make(ny, Array::make(nx, 0.0))
  let y = Array::make(ny, Array::make(nx, 0.0))
  
  for i = 0; i < ny; i = i + 1 {
    x[i] = Array::make(nx, 0.0)  // 为每行创建新数组
    y[i] = Array::make(nx, 0.0)  // 为每行创建新数组
    for j = 0; j < nx; j = j + 1 {
      x[i][j] = x_coords[j]
      y[i][j] = y_coords[i]
    }
  }
  
  (x, y)
}
// Build up the b array for pressure Poisson equation
fn build_up_b_array(b : Array[Array[Double]], rho : Double, dt : Double, 
                   u : Array[Array[Double]], v : Array[Array[Double]], 
                   dx : Double, dy : Double) -> Array[Array[Double]] {
  
  // Equivalent to b[1:-1, 1:-1] = ... in Python
  for i = 1; i < ny - 1; i = i + 1 {
    for j = 1; j < nx - 1; j = j + 1 {
      // Calculate velocity divergence terms
      let du_dx = (u[i][j + 1] - u[i][j - 1]) / (2.0 * dx)
      let dv_dy = (v[i + 1][j] - v[i - 1][j]) / (2.0 * dy)
      
      // Calculate squared terms
      let du_dx_squared = du_dx * du_dx
      let dv_dy_squared = dv_dy * dv_dy
      
      // Mixed derivative terms
      let du_dy = (u[i + 1][j] - u[i - 1][j]) / (2.0 * dy)
      let dv_dx = (v[i][j + 1] - v[i][j - 1]) / (2.0 * dx)
      let mixed_term = 2.0 * du_dy * dv_dx
      
      // Assemble the source term
      b[i][j] = rho * (
        (1.0 / dt) * (du_dx + dv_dy) - 
        du_dx_squared - 
        mixed_term - 
        dv_dy_squared
      )
    }
  }
  
  b
}
// Pressure Poisson equation solver
fn pressure_poisson_array(p : Array[Array[Double]], dx : Double, dy : Double, 
                         b : Array[Array[Double]]) -> Array[Array[Double]] {
  let pn = create_zeros_2d(ny, nx)
  let dx2 = dx * dx
  let dy2 = dy * dy
  let coeff = dx2 * dy2 / (2.0 * (dx2 + dy2))
  let inv_denom = 1.0 / (2.0 * (dx2 + dy2))
  
  for q = 0; q < nit; q = q + 1 {
    copy_2d_array(p, pn)
    
    // Update interior points: p[1:-1, 1:-1] = ...
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let laplacian = (pn[i][j + 1] + pn[i][j - 1]) * dy2 + 
                       (pn[i + 1][j] + pn[i - 1][j]) * dx2
        
        p[i][j] = laplacian * inv_denom - coeff * b[i][j]
      }
    }
    
    // Apply boundary conditions
    // p[:, -1] = p[:, -2]  (dp/dx = 0 at x = 2)
    for i = 0; i < ny; i = i + 1 {
      p[i][nx - 1] = p[i][nx - 2]
    }
    
    // p[0, :] = p[1, :]  (dp/dy = 0 at y = 0)
    for j = 0; j < nx; j = j + 1 {
      p[0][j] = p[1][j]
    }
    
    // p[:, 0] = p[:, 1]  (dp/dx = 0 at x = 0)
    for i = 0; i < ny; i = i + 1 {
      p[i][0] = p[i][1]
    }
    
    // p[-1, :] = 0  (p = 0 at y = 2)
    for j = 0; j < nx; j = j + 1 {
      p[ny - 1][j] = 0.0
    }
  }
  
  p
}
// Main cavity flow solver function
///|
fn cavity_flow_array(
  nt : Int,
  u : Array[Array[Double]],
  v : Array[Array[Double]],
  dt : Double,
  dx : Double,
  dy : Double,
  p : Array[Array[Double]],
  rho : Double,
  nu : Double,
) -> (Array[Array[Double]], Array[Array[Double]], Array[Array[Double]]) {
  let un = create_zeros_2d(ny, nx)
  let vn = create_zeros_2d(ny, nx)
  let b = create_zeros_2d(ny, nx)

  for n = 0; n < nt; n = n + 1 {
    copy_2d_array(u, un)
    copy_2d_array(v, vn)

    // Build up b array
    build_up_b_array(b, rho, dt, u, v, dx, dy) |> ignore

    // Solve pressure Poisson equation
    pressure_poisson_array(p, dx, dy, b) |> ignore

    // Update u velocity component
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let conv_u_x = un[i][j] * dt / dx * (un[i][j] - un[i][j - 1])
        let conv_u_y = vn[i][j] * dt / dy * (un[i][j] - un[i - 1][j])
        let pressure_grad = dt / (2.0 * rho * dx) * (p[i][j + 1] - p[i][j - 1])
        let visc_u_x = nu *
          dt /
          (dx * dx) *
          (un[i][j + 1] - 2.0 * un[i][j] + un[i][j - 1])
        let visc_u_y = nu *
          dt /
          (dy * dy) *
          (un[i + 1][j] - 2.0 * un[i][j] + un[i - 1][j])

        u[i][j] = un[i][j] -
          conv_u_x -
          conv_u_y -
          pressure_grad +
          visc_u_x +
          visc_u_y
      }
    }

    // Update v velocity component
    for i = 1; i < ny - 1; i = i + 1 {
      for j = 1; j < nx - 1; j = j + 1 {
        let conv_v_x = un[i][j] * dt / dx * (vn[i][j] - vn[i][j - 1])
        let conv_v_y = vn[i][j] * dt / dy * (vn[i][j] - vn[i - 1][j])
        let pressure_grad = dt / (2.0 * rho * dy) * (p[i + 1][j] - p[i - 1][j])
        let visc_v_x = nu *
          dt /
          (dx * dx) *
          (vn[i][j + 1] - 2.0 * vn[i][j] + vn[i][j - 1])
        let visc_v_y = nu *
          dt /
          (dy * dy) *
          (vn[i + 1][j] - 2.0 * vn[i][j] + vn[i - 1][j])

        v[i][j] = vn[i][j] -
          conv_v_x -
          conv_v_y -
          pressure_grad +
          visc_v_x +
          visc_v_y
      }
    }

    // Apply velocity boundary conditions
    // u[0, :] = 0, u[:, 0] = 0, u[:, -1] = 0
    for j = 0; j < nx; j = j + 1 {
      u[0][j] = 0.0
    }
    for i = 0; i < ny; i = i + 1 {
      u[i][0] = 0.0
      u[i][nx - 1] = 0.0
    }
    // u[-1, :] = 1 (cavity lid velocity)
    for j = 0; j < nx; j = j + 1 {
      u[ny - 1][j] = 1.0
    }

    // v[0, :] = 0, v[-1, :] = 0, v[:, 0] = 0, v[:, -1] = 0
    for j = 0; j < nx; j = j + 1 {
      v[0][j] = 0.0
      v[ny - 1][j] = 0.0
    }
    for i = 0; i < ny; i = i + 1 {
      v[i][0] = 0.0
      v[i][nx - 1] = 0.0
    }

    // Progress output every 10 steps
    if (n + 1) % 10 == 0 {
      println("Time step \{n + 1}/\{nt} completed")
    }
  }

  (u, v, p)
}

//test (b : @bench.T) {
//b.bench(fn() { b.keep(cavity_flow_array(nt_test, u, v, dt, dx, dy, p, rho, nu)) })
//}

fn fib(n : Int) -> Int {
  if n < 2 {
    return n
  }
  return fib(n - 1) + fib(n - 2)
}

test (b : @bench.T) {
  b.bench(fn() { b.keep(fib(20)) })
}

// Function to write velocity data to a text file
fn write_velocity_to_file(u : Array[Array[Double]], v : Array[Array[Double]], 
                         x : Array[Array[Double]], y : Array[Array[Double]], 
                         filename : String) -> Unit {
  // Note: MoonBit doesn't have built-in file I/O in the standard library
  // This is a placeholder implementation that would need platform-specific file I/O
  println("Writing velocity data to file: \{filename}")
  println("File format: x, y, u, v, velocity_magnitude")
  println("Data points:")
  
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let x_pos = x[i][j]
      let y_pos = y[i][j]
      let u_val = u[i][j]
      let v_val = v[i][j]
      let vel_mag = (u_val * u_val + v_val * v_val).sqrt()
      
      // In a real implementation, this would write to a file
      // For now, we'll print to console with file-like formatting
      println("\{x_pos}, \{y_pos}, \{u_val}, \{v_val}, \{vel_mag}")
    }
  }
  
  println("Velocity data written to \{filename} (simulated)")
}
// 添加用于浏览器展示的辅助函数
fn create_visualization_data(u : Array[Array[Double]], v : Array[Array[Double]], 
                           x : Array[Array[Double]], y : Array[Array[Double]]) -> String {
  let mut result = "["
  
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let x_pos = x[i][j]
      let y_pos = y[i][j]
      let u_val = u[i][j]
      let v_val = v[i][j]
      let vel_mag = (u_val * u_val + v_val * v_val).sqrt()
      
      if i > 0 || j > 0 {
        result = result + ","
      }
      
      result = result + "{"
      result = result + "\"x\":" + x_pos.to_string() + ","
      result = result + "\"y\":" + y_pos.to_string() + ","
      result = result + "\"u\":" + u_val.to_string() + ","
      result = result + "\"v\":" + v_val.to_string() + ","
      result = result + "\"magnitude\":" + vel_mag.to_string() + ","
      result = result + "\"i\":" + i.to_string() + ","
      result = result + "\"j\":" + j.to_string()
      result = result + "}"
    }
  }
  
  result = result + "]"
  result
}
// 导出函数供浏览器调用
pub fn get_simulation_config() -> String {
  "{\"nx\":" + nx.to_string() + 
  ",\"ny\":" + ny.to_string() + 
  ",\"nt\":" + nt.to_string() + 
  ",\"dx\":" + dx.to_string() + 
  ",\"dy\":" + dy.to_string() + 
  ",\"rho\":" + rho.to_string() + 
  ",\"nu\":" + nu.to_string() + 
  ",\"dt\":" + dt.to_string() + "}"
}
// 主要的模拟函数，返回结果数据
pub fn run_cavity_simulation() -> String {
  // 初始化数组
  let u = create_zeros_2d(ny, nx)
  let v = create_zeros_2d(ny, nx)
  let p = create_zeros_2d(ny, nx)
  
  // 生成网格
  let (x, y) = generate_mesh_grid()
  
  // 运行模拟（使用较少的时间步以提高浏览器性能）
  let nt_browser = 50
  let (u_final, v_final, _p_final) = cavity_flow_array(nt_browser, u, v, dt, dx, dy, p, rho, nu)
  
  // 创建可视化数据
  let data = create_visualization_data(u_final, v_final, x, y)
  
  // 返回完整的JSON数据
  "{\"config\":" + get_simulation_config() + ",\"data\":" + data + "}"
}
// 用于浏览器调试的简化版本
pub fn run_simple_simulation() -> String {
  let u = create_zeros_2d(21, 21)  // 使用更小的网格
  let v = create_zeros_2d(21, 21)
  let _p = create_zeros_2d(21, 21)
  
  // 设置一些简单的测试数据
  for i = 0; i < 21; i = i + 1 {
    for j = 0; j < 21; j = j + 1 {
      u[i][j] = (i.to_double() - 10.0) / 10.0
      v[i][j] = (j.to_double() - 10.0) / 10.0
    }
  }
  
  let mut result = "["
  for i = 0; i < 21; i = i + 1 {
    for j = 0; j < 21; j = j + 1 {
      if i > 0 || j > 0 {
        result = result + ","
      }
      let x_pos = j.to_double() / 10.0
      let y_pos = i.to_double() / 10.0
      let u_val = u[i][j]
      let v_val = v[i][j]
      let vel_mag = (u_val * u_val + v_val * v_val).sqrt()
      
      result = result + "{"
      result = result + "\"x\":" + x_pos.to_string() + ","
      result = result + "\"y\":" + y_pos.to_string() + ","
      result = result + "\"u\":" + u_val.to_string() + ","
      result = result + "\"v\":" + v_val.to_string() + ","
      result = result + "\"magnitude\":" + vel_mag.to_string()
      result = result + "}"
    }
  }
  result = result + "]"
  result
}

// Main function to run the cavity flow simulation
fn main {
  // Program timing placeholders.
  // NOTE: MoonBit may not provide a built-in timing API in this environment.
  // To enable accurate timing, bind a host function (e.g., JS `Date.now()` for WASM
  // or a native clock) to return a Double seconds-since-epoch value and assign
  // it to `program_start` below.
  let program_start = now_seconds()
  let have_timer = program_start > 0.0

  println("=== 2D Cavity Flow Solver (Array-based Implementation) ===")
  println("Grid: \{nx}x\{ny}, Time steps: \{nt}")
  println("Parameters: rho=\{rho}, nu=\{nu}, dt=\{dt}")
  println("")
  
  // Initialize arrays
  let u = create_zeros_2d(ny, nx)
  let v = create_zeros_2d(ny, nx)
  let p = create_zeros_2d(ny, nx)
  
  // Generate mesh grid (修正：正确获取返回值)
  let (x, y) = generate_mesh_grid()
  
  // Run simulation with reduced time steps for testing
  let nt_test = 100
  println("Running simulation...")
  // Simulation timing placeholders. Replace `sim_start`/`sim_end` with real
  // timestamps if you bind a host timing function.
  let sim_start = now_seconds()

  let (u_final, v_final, p_final) = cavity_flow_array(nt_test, u, v, dt, dx, dy, p, rho, nu)

  //test (b : @bench.T) {
  //b.bench(fn() { b.keep(cavity_flow_array(nt_test, u, v, dt, dx, dy, p, rho, nu)) })
  //}

  let sim_end = now_seconds()

  if sim_start > 0.0 && sim_end > 0.0 {
    let sim_elapsed = sim_end - sim_start
    println("Simulation runtime (seconds): \{sim_elapsed}")
  } else {
    println("Simulation runtime: timing API unavailable in this environment")
  }
  
  // Post-processing: calculate velocity magnitude at center
  let mid_i = ny / 2
  let mid_j = nx / 2
  let u_center = u_final[mid_i][mid_j]
  let v_center = v_final[mid_i][mid_j]
  let p_center = p_final[mid_i][mid_j]
  let vel_mag_center = (u_center * u_center + v_center * v_center).sqrt()
  
  println("")
  println("=== Post-processing Results ===")
  println("Results at center (\{mid_i}, \{mid_j}):")
  println("  u = \{u_center}")
  println("  v = \{v_center}")
  println("  p = \{p_center}")
  println("  |V| = \{vel_mag_center}")
  println("  X at center = \{x[mid_i][mid_j]}")  // 现在可以使用X
  println("  Y at center = \{y[mid_i][mid_j]}")  // 现在可以使用Y
  
  // Print some velocity values along the top lid
  println("")
  println("Top lid velocity profile:")
  for j = 0; j < nx; j = j + 5 {
    let x_pos = x[ny - 1][j]  // 使用mesh grid的X坐标
    println("  x=\{x_pos}: u=\{u_final[ny - 1][j]}")
  }
  
  // Find maximum values
  let mut max_u = 0.0
  let mut max_v = 0.0
  let mut max_p = 0.0
  let mut min_p = 0.0
  
  for i = 0; i < ny; i = i + 1 {
    for j = 0; j < nx; j = j + 1 {
      let u_val = u_final[i][j]
      let v_val = v_final[i][j]
      let p_val = p_final[i][j]
      
      if u_val.abs() > max_u { max_u = u_val.abs() }
      if v_val.abs() > max_v { max_v = v_val.abs() }
      if p_val > max_p { max_p = p_val }
      if p_val < min_p { min_p = p_val }
    }
  }
  
  println("")
  println("Field statistics:")
  println("  Max |u|: \{max_u}")
  println("  Max |v|: \{max_v}")
  println("  Pressure range: [\{min_p}, \{max_p}]")
  
  // Calculate velocity magnitude at a few sample points
  println("")
  println("Velocity magnitude at sample points:")
  let sample_points = [(5, 5), (10, 10), (20, 20), (30, 30)]
  for i = 0; i < sample_points.length(); i = i + 1 {
    let (si, sj) = sample_points[i]
    if si < ny && sj < nx {
      let u_sample = u_final[si][sj]
      let v_sample = v_final[si][sj]
      let vel_mag_sample = (u_sample * u_sample + v_sample * v_sample).sqrt()
      println("  Point (\{si}, \{sj}): |V| = \{vel_mag_sample}")
    }
  }
  // Add this code after the sample points calculation and before the final completion message
  println("")
  println("=== Writing velocity data to file ===")

  // Write all velocity data to a text file
  write_velocity_to_file(u_final, v_final, x, y, "velocity_field.txt")

  println("Velocity data export completed.")
  println("")
  println("=== Simulation completed successfully ===")
  println("")
  println("Note: Plotting functions are not implemented:")
  println("- 3D surface plots (equivalent to matplotlib's ax.plot_surface)")
  println("- Contour plots (equivalent to pyplot.contourf)")  
  println("- Vector field plots (equivalent to pyplot.quiver)")
  println("- Image saving (equivalent to pyplot.savefig)")
  println("The computed data is available in u_final, v_final, p_final arrays")
  println("for external visualization tools.")

  // Program end time placeholder. Replace `program_end` with a real timestamp
  // from a host binding to enable total runtime reporting.
  let program_end = now_seconds()

  if have_timer && program_start > 0.0 && program_end > 0.0 {
    let total_elapsed = program_end - program_start
    println("Total program runtime (seconds): \{total_elapsed}")
  } else if !have_timer {
    println("Total program runtime: timing API unavailable in this environment")
  }
}
